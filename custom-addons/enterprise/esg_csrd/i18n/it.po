msgstr "<strong>Anno di adozione</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid "<strong>[describe how sustainability affects strategy]</strong>"
msgstr ""
"<strong>[descrivi in che modo la sostenibilità influisce sulla strategia]</"
"strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid "<strong>[describe key markets and customer types]</strong>"
msgstr "<strong>[descrivi i mercati chiave e le tipologie di clienti]</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid ""
"<strong>[describe key suppliers, partners, customers, and channels]</strong>"
msgstr ""
"<strong>[descrivi i principali fornitori, partner, clienti e canali]</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid "<strong>[describe significant product/service groups]</strong>"
msgstr "<strong>[descrivi gruppi significativi di prodotti/servizi]</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e5
msgid ""
"<strong>{{ company_name }}</strong> aims to decouple economic growth from\n"
"                        material consumption, reduce waste generation, and "
"enhance resource\n"
"                        efficiency in line with the EU Circular Economy "
"Action Plan."
msgstr ""
"<strong>{{ company_name }}</strong> mira a separare la crescita economica "
"dal\n"
"                        consumo di materiali, ridurre la produzione di "
"rifiuti e migliorare l'efficienza delle risorse\n"
"                        in linea con il Piano d'azione dell'UE per "
"l'economia circolare."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> applies a Community Engagement\n"
"                                        Policy and Human-Rights Policy "
"covering social inclusion,\n"
"                                        consultation, and impact mitigation. "
"Policies are aligned\n"
"                                        with the UN Guiding Principles on "
"Business and Human Rights\n"
"                                        and OECD standards."
msgstr ""
"<strong>{{ company_name }}</strong> applica una Politica di coinvolgimento "
"della comunità\n"
"                                        e una Politica sui diritti umani che "
"coprono l'inclusione sociale,\n"
"                                        la consultazione e la mitigazione "
"dell'impatto. Le politiche sono allineate\n"
"                                        ai Principi guida delle Nazioni "
"Unite su imprese e diritti umani\n"
"                                        e agli standard dell'OCSE."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> applies a Responsible Sourcing\n"
"                                    Policy and Supplier Code of Conduct "
"covering labor rights,\n"
"                                    working conditions, and ethical "
"practices."
msgstr ""
"<strong>{{ company_name }}</strong> applica una Politica di "
"approvvigionamento responsabile\n"
"                                    e un Codice di condotta dei fornitori "
"che coprono i diritti dei lavoratori,\n"
"                                    le condizioni di lavoro e le pratiche "
"etiche."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s4
msgid ""
"<strong>{{ company_name }}</strong> applies policies on product\n"
"                                        safety, ethical marketing, consumer "
"privacy, and complaint\n"
"                                        handling. Policies align with "
"international standards such\n"
"                                        as <em>\n"
"                                            <strong>ISO 9001, ISO 26000, and "
"consumer protection\n"
"                                        regulations.</strong>\n"
"                                        </em>"
msgstr ""
"<strong>{{ company_name }}</strong> applica politiche in materia di\n"
"                                        sicurezza dei prodotti, marketing "
"etico, privacy dei consumatori e gestione dei reclami\n"
"                                        . Le politiche sono in linea con "
"standard internazionali\n"
"                                        quali<em>\n"
"                                        <strong> ISO 9001, ISO 26000 e le "
"normative sulla tutela dei\n"
"                                            consumatori.</strong>\n"
"                                        </em>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e4
msgid ""
"<strong>{{ company_name }}</strong> assesses financial\n"
"                                            exposure to\n"
"                                            water-related risks (scarcity, "
"regulation, pollution\n"
"                                            events) and\n"
"                                            potential opportunities (cost "
"savings, sustainable\n"
"                                            branding). These\n"
"                                            assessments are integrated into "
"the enterprise risk\n"
"                                            management framework\n"
"                                            and scenario analyses."
msgstr ""
"<strong>{{ company_name }}</strong> valuta l'esposizione finanziaria\n"
"                                            ai\n"
"                                            rischi legati all'acqua "
"(scarsità, regolamentazione, eventi di inquinamento\n"
"                                            ) e le\n"
"                                            potenziali opportunità "
"(risparmio sui costi, branding sostenibile\n"
"                                            ). Queste\n"
"                                            valutazioni sono integrate nel "
"quadro di gestione del rischio aziendale\n"
"                                            e nelle analisi di scenario."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"<strong>{{ company_name }}</strong> assesses financial\n"
"                                        exposure to\n"
"                                        water-related risks (scarcity, "
"regulation, pollution events)\n"
"                                        and potential\n"
"                                        opportunities (cost savings, "
"sustainable branding). These\n"
"                                        assessments are\n"
"                                        integrated into the enterprise risk "
"management framework and\n"
"                                        scenario\n"
"                                        analyses."
msgstr ""
"<strong>{{ company_name }}</strong> valuta l'esposizione finanziaria\n"
"                                        ai\n"
"                                        rischi legati all'acqua (scarsità, "
"regolamentazione, eventi di inquinamento)\n"
"                                        e le potenziali\n"
"                                        opportunità (risparmio sui costi, "
"branding sostenibile). Queste\n"
"                                        valutazioni sono\n"
"                                        integrate nel quadro di gestione del "
"rischio aziendale e nelle\n"
"                                        analisi di scenario\n"
"                                        ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> assesses financial exposure to\n"
"                                pollution-related risks, including "
"regulatory changes, accidental\n"
"                                releases, and contamination of air, water, "
"and soil."
msgstr ""
"<strong>{{ company_name }}</strong> valuta l'esposizione finanziaria ai\n"
"                                rischi legati all'inquinamento, inclusi "
"cambiamenti normativi,\n"
"                                rilasci accidentali e contaminazione di "
"aria, acqua e suolo."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> assesses financial exposure to both\n"
"                                physical climate risks (e.g., extreme "
"weather, heat, flooding) and\n"
"                                transition risks (e.g., carbon pricing, "
"regulatory change,\n"
"                                technology shifts)."
msgstr ""
"<strong>{{ company_name }}</strong> valuta l'esposizione finanziaria sia ai\n"
"                                rischi climatici fisici (ad es. condizioni "
"meteorologiche estreme, calore, inondazioni) sia ai\n"
"                                rischi di transizione (ad es. tariffazione "
"del carbonio, cambiamenti normativi,\n"
"                                cambiamenti tecnologici)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"<strong>{{ company_name }}</strong> calculates its GHG emissions following "
"the <strong>GHG Protocol</strong>\n"
"                and <strong>Le Bilan Carbone®</strong> methodology. The "
"emissions are categorized\n"
"                into:"
msgstr ""
"<strong>{{ company_name }}</strong> calcola le proprie emissioni di gas "
"serra seguendo il <strong>GHG Protocol</strong> \n"
"                e la metodologia <strong>Le Bilan Carbone®</strong> "
"metodologia. Le emissioni sono classificate\n"
"                in:"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> engages communities via consultations, "
"town halls,\n"
"                                                surveys, and collaborative "
"projects. Engagement\n"
"                                                identifies risks such as "
"displacement, environmental\n"
"                                                harm, or lack of economic "
"opportunities. Outcomes\n"
"                                                inform mitigation and "
"investment plans."
msgstr ""
"<strong>{{ company_name }}</strong> coinvolge le community tramite "
"consultazioni, assemblee pubbliche,\n"
"                                                sondaggi e Progetti "
"collaborativi. Il coinvolgimento\n"
"                                                identifica rischi quali lo "
"sfollamento, i danni ambientali\n"
"                                                o la mancanza di opportunità "
"economiche. I risultati\n"
"                                                informano i piani di "
"mitigazione e di investimento."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> engages suppliers and their workers "
"through audits,\n"
"                                            surveys, and dialogue<strong>\n"
"                                                <em> platforms</em>\n"
"                                            </strong><em>\n"
"                                            .</em>Engagement aims to "
"identify and address issues\n"
"                                            such as excessive overtime, "
"discrimination, or lack of\n"
"                                            worker representation. Findings "
"feed into\n"
"                                            supplier-improvement plans."
msgstr ""
"<strong>{{ company_name }}</strong> coinvolge fornitori e lavoratori tramite "
"audit,\n"
"                                            sondaggi e piattaforme<strong>\n"
"                                                <em> di dialogo</em>\n"
"                                            </strong><em>\n"
"                                            .</em>La partecipazione punta a "
"individuare e indirizzare i problemi\n"
"                                            come straordinari eccessivi, "
"discriminazione o mancanza di\n"
"                                            rappresentazione dei lavoratori. "
"I risultati aiutano a creare\n"
"                                            piani di miglioramento dei "
"fornitori."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> engages workers via surveys, focus\n"
"                                groups, and consultation committees to "
"capture views on workplace\n"
"                                conditions and workforce impacts."
msgstr ""
"<strong>{{ company_name }}</strong> coinvolge i lavoratori tramite sondaggi, "
"focus\n"
"                                group e comitati consultivi per raccogliere "
"opinioni sulle condizioni di lavoro\n"
"                                e sull'impatto sulla forza lavoro."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> ensures that all workers receive\n"
"                                wages meeting or exceeding legal minimums "
"and living wage benchmarks\n"
"                                where available. Regular reviews assess wage "
"competitiveness and\n"
"                                internal equity."
msgstr ""
"<strong>{{ company_name }}</strong> garantisce che tutti i lavoratori "
"ricevano\n"
"                                salari pari o superiori ai minimi legali e "
"ai parametri di riferimento del salario di sussistenza\n"
"                                ove disponibili. Revisioni periodiche "
"valutano la competitività salariale e\n"
"                                l'equità interna."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> ensures that employees have the\n"
"                                right to freedom of association and "
"collective bargaining. Social\n"
"                                dialogue occurs through regular meetings "
"between management and\n"
"                                employee representatives at site and group "
"levels. Collective\n"
"                                agreements define working conditions, pay, "
"and benefits where\n"
"                                applicable."
msgstr ""
"<strong>{{ company_name }}</strong> garantisce che i dipendenti abbiano il\n"
"                                diritto alla libertà di associazione e alla "
"contrattazione collettiva. Il dialogo sociale\n"
"                                avviene attraverso incontri regolari tra la "
"direzione e i\n"
"                                rappresentanti dei dipendenti a livello di "
"sito e di gruppo. I contratti collettivi\n"
"                                definiscono le condizioni di lavoro, la "
"retribuzione e i benefici, ove\n"
"                                applicabile."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e5
msgid ""
"<strong>{{ company_name }}</strong> evaluates\n"
"                                            financial impacts from\n"
"                                            resource-use and circular-"
"economy risks, integrating\n"
"                                            them into\n"
"                                            enterprise risk management. "
"Opportunities include\n"
"                                            cost savings,\n"
"                                            access to green financing, and "
"market growth for\n"
"                                            circular products."
msgstr ""
"<strong>{{ company_name }}</strong> valuta\n"
"                                            gli impatti finanziari derivanti "
"dai\n"
"                                            rischi legati all'uso delle "
"risorse e all'economia circolare, integrandoli\n"
"                                            nella\n"
"                                            gestione del rischio aziendale. "
"Le opportunità includono\n"
"                                            risparmi sui costi,\n"
"                                            accesso a finanziamenti verdi e "
"crescita del mercato per i\n"
"                                            prodotti circolari."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> fosters inclusion for persons with "
"disabilities through\n"
"                                accessible recruitment, workplace "
"adaptation, and dedicated\n"
"                                training. Progress is monitored via self-"
"identification and HR\n"
"                                systems."
msgstr ""
"<strong>{{ company_name }}</strong> promuove l'inclusione delle persone con "
"disabilità attraverso\n"
"                                reclutamento accessibile, adattamento del "
"posto di lavoro e formazione dedicata\n"
"                                . I progressi vengono monitorati tramite "
"l'autoidentificazione e i sistemi delle risorse umane\n"
"                                ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e4
msgid ""
"<strong>{{ company_name }}</strong> has developed a transition plan\n"
"                                    to ensure its business model and "
"strategy are compatible with\n"
"                                    global ecological thresholds, <strong>\n"
"                                        <em>including the Post-2020 Global "
"Biodiversity Framework\n"
"                                            and the EU\n"
"                                            Biodiversity Strategy for 2030</"
"em>\n"
"                                    </strong>.\n"
"                                    The plan addresses material impacts and "
"dependencies on\n"
"                                    biodiversity and ecosystems across own "
"operations and the value\n"
"                                    chain, using the mitigation hierarchy: "
"avoid, reduce, restore,\n"
"                                    and offset. Short-term (2025), medium-"
"term (2030), and long-term\n"
"                                    (2040-2050) milestones are defined, with "
"governance approval and\n"
"                                    monitoring systems in place."
msgstr ""
"<strong>{{ company_name }}</strong> ha sviluppato un piano di transizione\n"
"                                    per garantire che il proprio modello di "
"business e la propria strategia siano compatibili con\n"
"                                    le soglie ecologiche globali,<strong>\n"
"                                            <em>tra cui il Quadro globale "
"per la biodiversità post-2020\n"
"                                            e la Strategia dell'UE\n"
"                                    per la biodiversità per il 2030</em>.\n"
"                                    </strong>.\n"
"                                    Il piano affronta gli impatti "
"significativi e le dipendenze dalla\n"
"                                    biodiversità e dagli ecosistemi in tutte "
"le proprie operazioni e nella catena del valore\n"
"                                    utilizzando la gerarchia di mitigazione: "
"evitare, ridurre, ripristinare\n"
"                                    e compensare. Sono definiti obiettivi a "
"breve termine (2025), a medio termine (2030) e a lungo termine\n"
"                                        (2040-2050), con l'approvazione "
"della governance e\n"
"                                    sistemi di monitoraggio in atto."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> has established a transition plan\n"
"                                to align its activities with a 1.5°C "
"pathway, achieving net-zero GHG\n"
"                                emissions by <strong>\n"
"                                    <em>[insert year]</em>\n"
"                                </strong>.\n"
"                                The plan includes short-term (2025), medium-"
"term (2030), and\n"
"                                long-term (2040-2050) milestones."
msgstr ""
"<strong>{{ company_name }}</strong> ha stabilito un piano di transizione\n"
"                                per allineare le proprie attività a un "
"percorso di 1,5 °C, raggiungendo emissioni nette di gas serra pari a zero\n"
"                                entro il [inserire l'anno] .\n"
"                                Il piano include traguardi a breve termine "
"(2025), a medio termine (2030) e\n"
"                                a lungo termine (2040-2050). <strong>\n"
"                                    <em></em>\n"
"                                </strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> identifies substances of concern\n"
"                                (including SVHCs) in operations, products, "
"and supply chains.\n"
"                                Management measures include substitution, "
"safe handling, and\n"
"                                tracking of quantities used."
msgstr ""
"<strong>{{ company_name }}</strong> identifica le sostanze che destano "
"preoccupazione\n"
"                                (comprese le SVHC) nelle operazioni, nei "
"prodotti e nelle catene di approvvigionamento.\n"
"                                Le misure di gestione includono la "
"sostituzione, la manipolazione sicura e\n"
"                                il monitoraggio delle quantità utilizzate."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> implements\n"
"                                    supplier-training programs, capacity-"
"building partnerships, and\n"
"                                    collaborative industry initiatives to "
"reduce negative impacts on\n"
"                                    value-chain workers. Effectiveness is "
"evaluated by improvements\n"
"                                    in audit results, reduced complaints, "
"and supplier retention\n"
"                                    rates."
msgstr ""
"<strong>{{ company_name }}</strong> attua\n"
"                                    programmi di formazione dei fornitori, "
"partnership per lo sviluppo delle capacità e\n"
"                                    iniziative collaborative del settore per "
"ridurre gli impatti negativi sui\n"
"                                    lavoratori della catena del valore. "
"L'efficacia viene valutata in base ai miglioramenti\n"
"                                    nei risultati degli audit, alla "
"riduzione dei reclami e ai tassi di fidelizzazione dei fornitori\n"
"                                    ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> implements community-investment\n"
"                                            programs, livelihood "
"initiatives, and collaborative\n"
"                                            mitigation projects. "
"Effectiveness is evaluated by\n"
"                                            reductions in complaints, "
"improved community\n"
"                                            satisfaction, and measurable "
"social outcomes."
msgstr ""
"<strong>{{ company_name }}</strong> attua programmi di investimento nella "
"comunità,\n"
"                                            iniziative per il sostentamento "
"e progetti collaborativi\n"
"                                            di mitigazione. L'efficacia "
"viene valutata in base alla\n"
"                                            riduzione dei reclami, al "
"miglioramento della soddisfazione della comunità\n"
"                                            e a risultati sociali misurabili."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> implements group-wide climate and\n"
"                                energy policies to steer operations toward "
"decarbonization and\n"
"                                resilience. Policies are endorsed by the "
"Board and integrated into\n"
"                                corporate governance."
msgstr ""
"<strong>{{ company_name }}</strong> attua politiche climatiche ed "
"energetiche a livello di gruppo\n"
"                                per orientare le operazioni verso la "
"decarbonizzazione e la\n"
"                                resilienza. Le politiche sono approvate dal "
"Consiglio di Amministrazione e integrate nella\n"
"                                governance aziendale."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> implements group-wide pollution\n"
"                                policies endorsed by the Board, integrated "
"into operational\n"
"                                management and governance. Policies cover "
"prevention, monitoring,\n"
"                                and reporting of environmental impacts."
msgstr ""
"<strong>{{ company_name }}</strong> attua politiche di inquinamento a "
"livello di gruppo\n"
"                                approvate dal Consiglio, integrate nella "
"gestione operativa\n"
"                                e nella governance. Le politiche riguardano "
"la prevenzione, il monitoraggio\n"
"                                e la segnalazione degli impatti ambientali."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> integrates carbon-cost\n"
"                                considerations into its decision-making to "
"anticipate regulatory,\n"
"                                market, and transition risks. The company "
"applies an internal carbon\n"
"                                price to guide capital allocation and "
"project evaluation."
msgstr ""
"<strong>{{ company_name }}</strong> integra le considerazioni relative al "
"costo del carbonio\n"
"                                nel proprio processo decisionale per "
"anticipare i rischi normativi,\n"
"                                di mercato e di transizione. L'azienda "
"applica un prezzo interno del carbonio\n"
"                                per guidare l'allocazione del capitale e la "
"valutazione dei progetti."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> invests in continuous learning through "
"structured\n"
"                                programs, on-the-job training, and e-"
"learning. Focus areas include\n"
"                                digital skills, leadership, and "
"sustainability awareness."
msgstr ""
"<strong>{{ company_name }}</strong> investe nell'apprendimento continuo "
"attraverso\n"
"                                programmi strutturati, formazione sul posto "
"di lavoro ed e-learning. Le aree di interesse includono\n"
"                                le competenze digitali, la leadership e la "
"consapevolezza della sostenibilità."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"<strong>{{ company_name }}</strong> maintains comprehensive water\n"
"                                    and marine management policies approved "
"by senior leadership.\n"
"                                    These policies aim to ensure responsible "
"sourcing, efficient\n"
"                                    consumption, and safe return of water to "
"the environment, while\n"
"                                    safeguarding ocean ecosystems."
msgstr ""
"<strong>{{ company_name }}</strong> mantiene politiche complete di gestione "
"delle risorse idriche\n"
"                                    e marine approvate dalla dirigenza.\n"
"                                    Queste politiche mirano a garantire un "
"approvvigionamento responsabile, un consumo efficiente\n"
"                                    e un ritorno sicuro dell'acqua "
"nell'ambiente, salvaguardando al contempo\n"
"                                    gli ecosistemi oceanici."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_g1
msgid ""
"<strong>{{ company_name }}</strong> maintains corporate culture and\n"
"                                    business conduct policies covering "
"ethical behavior,\n"
"                                    whistleblowing, anti-corruption, and "
"responsible\n"
"                                    decision-making. Policies align with "
"OECD Guidelines, UN Global\n"
"                                    Compact, and ISO 37001 anti-bribery "
"standards."
msgstr ""
"<strong>{{ company_name }}</strong> mantiene la cultura aziendale e\n"
"                                    le politiche di condotta aziendale che "
"riguardano il comportamento etico,\n"
"                                    la segnalazione di irregolarità, "
"l'anticorruzione e il\n"
"                                    processo decisionale responsabile. Le "
"politiche sono in linea con le Linee guida dell'OCSE, il Global\n"
"                                    Compact delle Nazioni Unite e gli "
"standard anticorruzione ISO 37001."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid ""
"<strong>{{ company_name }}</strong> monitors additional workforce "
"characteristics to provide a complete view of its human capital management. "
"This section includes management-level gender ratios and information on self-"
"employed and temporary workers engaged by the company. Data is collected "
"from employee application."
msgstr ""
"<strong>{{ company_name }}</strong> monitora ulteriori caratteristiche della "
"forza lavoro per fornire una visione completa della gestione del capitale "
"umano. Questa sezione include i rapporti di genere a livello dirigenziale e "
"le informazioni sui lavoratori autonomi e temporanei assunti dall'azienda. I "
"dati vengono raccolti dalle candidature dei dipendenti."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> monitors any GHG removal activities\n"
"                                or carbon credit projects linked to its "
"operations. These may\n"
"                                include carbon sequestration in soils, "
"forests, or technological\n"
"                                capture, and participation in certified "
"carbon offset programs."
msgstr ""
"<strong>{{ company_name }}</strong> monitora qualsiasi attività di rimozione "
"dei gas serra\n"
"                                o progetti di crediti di carbonio collegati "
"alle sue operazioni. Questi possono\n"
"                                includere il sequestro del carbonio nel "
"suolo, nelle foreste o la cattura tecnologica\n"
"                                e la partecipazione a programmi certificati "
"di compensazione delle emissioni di carbonio."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> progressively increases renewable\n"
"                                energy share through Power Purchase "
"Agreements and on-site\n"
"                                generation."
msgstr ""
"<strong>{{ company_name }}</strong> aumenta progressivamente la quota di "
"energia rinnovabile\n"
"                                attraverso accordi di acquisto di energia e "
"generazione in loco\n"
"                                ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> promotes equal opportunity and\n"
"                                diversity at all levels. Metrics include "
"gender, age, nationality,\n"
"                                and underrepresented groups. Diversity "
"targets are integrated into\n"
"                                leadership evaluations and HR processes."
msgstr ""
"<strong>{{ company_name }}</strong> promuove le pari opportunità e\n"
"                                la diversità a tutti i livelli. Gli "
"indicatori includono genere, età, nazionalità\n"
"                                e gruppi sottorappresentati. Gli obiettivi "
"di diversità sono integrati nelle\n"
"                                valutazioni della leadership e nei processi "
"delle risorse umane."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> provides formal channels for\n"
"                                workers to report concerns, including "
"whistleblowing hotlines,\n"
"                                email, and direct contact with HR. "
"Remediation processes ensure\n"
"                                timely follow-up, investigation, and "
"resolution of issues."
msgstr ""
"<strong>{{ company_name }}</strong> fornisce canali formali per\n"
"                                consentire ai lavoratori di segnalare "
"problemi, tra cui linee telefoniche dedicate alle segnalazioni,\n"
"                                e-mail e contatto diretto con le risorse "
"umane. I processi di rimedio garantiscono\n"
"                                un tempestivo follow-up, indagine e "
"risoluzione delle questioni."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> quantifies its greenhouse-gas (GHG)\n"
"                                emissions following recognised accounting "
"principles consistent with\n"
"                                the GHG Protocol Corporate Standard and ESRS "
"E1-6."
msgstr ""
"<strong>{{ company_name }}</strong> quantifica le proprie emissioni di gas "
"serra (GES)\n"
"                                secondo principi contabili riconosciuti, in "
"linea con\n"
"                                lo standard aziendale GHG Protocol e l'ESRS "
"E1-6."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> tracks emissions and discharges\n"
"                                systematically across all relevant "
"operational sites. Data\n"
"                                collection is aligned with the EMS and "
"reported consistently to\n"
"                                management and regulatory authorities."
msgstr ""
"<strong>{{ company_name }}</strong> traccia sistematicamente le emissioni e "
"gli scarichi\n"
"                                in tutti i siti operativi rilevanti. La "
"raccolta dei dati\n"
"                                è allineata con l'EMS e riportata in modo "
"coerente alla\n"
"                                direzione e alle autorità di "
"regolamentazione."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
