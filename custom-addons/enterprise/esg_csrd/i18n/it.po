"                                            assicurandoti che coprano tutti "
"gli\n"
"                                            aspetti rilevanti e siano "
"accessibili a tutti i\n"
"                                            lavoratori interessati."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c4
