"                                            e i loro\n"
"                                            rappresentanti, assicurandoti "
"che tali processi siano\n"
"                                            efficaci e coprano\n"
"                                            tutti gli impatti rilevanti."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
