msgid "Incidents, Complaints, and Severe Human Rights Impacts (S1-17)"
msgstr "Incidenti, reclami e gravi violazioni dei diritti umani (S1-17)"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"Incidents, Complaints, and Severe Human Rights Impacts (S1-17) <span "
