msgid ""
"<strong>\n"
"                                    <em>{{ company_name }}</em>\n"
"                                </strong>operates\n"
"                                grievance mechanisms enabling confidential "
"reporting of workplace\n"
"                                concerns, including discrimination, "
"harassment, or labor rights\n"
"                                breaches. All cases are logged, "
"investigated, and remediated. Severe\n"
"                                impacts are escalated to executive level and "
"disclosed\n"
"                                transparently."
msgstr ""
"<strong>\n"
"                                    <em>{{ company_name }}</em>\n"
"                               </strong> attiva\n"
"                                meccanismi di reclamo che consentono la "
"segnalazione riservata di preoccupazioni relative al posto di lavoro,\n"
"                                tra cui discriminazione, molestie o "
"violazioni dei diritti dei lavoratori.\n"
"                                Tutti i casi vengono registrati, indagati e "
"risolti. Gli impatti gravi\n"
"                                vengono segnalati al livello esecutivo e "
"divulgati\n"
"                                in modo trasparente."

