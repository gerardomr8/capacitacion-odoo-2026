"These are integrated within the enterprise-risk-management\n"
"                                process and linked to scenario analysis "
"aligned with the Paris\n"
"                                Agreement."
msgstr ""
"وهذه مدمجة ضمن عملية إدارة المخاطر المؤسسية\n"
"                                ومرتبطة بتحليل السيناريوهات المتوافق مع "
"اتفاقية باريس\n"
"                                ."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_metrics_targets
