#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_b8
msgid "“Not reported” includes employees who choose not to disclose gender."
msgstr ""
"\"No indicado\" incluye a los empleados que prefieren no compartir "
"información sobre su género."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_placeholders
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_appendix_b
