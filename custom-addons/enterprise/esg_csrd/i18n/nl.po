#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s4
msgid "Disclosure Requirements"
msgstr "Rapportage-eisen"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_iro_management
msgid ""
"Disclosure requirements in ESRS covered by the undertaking's\n"
"                        sustainability statement (IRO-2)"
msgstr ""
"Rapportage-eisen in de ESRS die in de duurzaamheidsverklaring van de "
"onderneming worden behandeld (IRO-2)"

#. module: esg_csrd
