msgid "<strong>[describe key markets and customer types]</strong>"
msgstr "<strong>[beschrijf belangrijke markten en klanttypes]</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid ""
"<strong>[describe key suppliers, partners, customers, and channels]</strong>"
msgstr ""
"<strong>[beschrijf belangrijke leveranciers, partners, klanten en kanalen]</"
"strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid "<strong>[describe significant product/service groups]</strong>"
msgstr "<strong>[beschrijf belangrijke product-/dienstgroepen]</strong>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e5
msgid ""
"<strong>{{ company_name }}</strong> aims to decouple economic growth from\n"
"                        material consumption, reduce waste generation, and "
"enhance resource\n"
"                        efficiency in line with the EU Circular Economy "
"Action Plan."
msgstr ""
"<strong>{{ company_name }}</strong> streeft ernaar om economische groei los "
"te koppelen van materiaalverbruik, afvalproductie te verminderen en de "
"efficiëntie van hulpbronnen te verbeteren in lijn met het EU-actieplan voor "
"de circulaire economie."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> applies a Community Engagement\n"
"                                        Policy and Human-Rights Policy "
"covering social inclusion,\n"
"                                        consultation, and impact mitigation. "
"Policies are aligned\n"
"                                        with the UN Guiding Principles on "
"Business and Human Rights\n"
"                                        and OECD standards."
msgstr ""
"<strong>{{ company_name }}</strong> hanteert een beleid voor betrokkenheid "
"van de gemeenschap en een mensenrechtenbeleid dat sociale inclusie, "
"raadpleging en mitigatie van effecten dekt. Het beleid is in lijn met de "
"leidende beginselen van de VN inzake bedrijfsleven en mensenrechten en de "
"OESO-normen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> applies a Responsible Sourcing\n"
"                                    Policy and Supplier Code of Conduct "
"covering labor rights,\n"
"                                    working conditions, and ethical "
"practices."
msgstr ""
"<strong>{{ company_name }}</strong> hanteert een beleid voor verantwoorde "
"inkoop en een gedragscode voor leveranciers die arbeidsrechten, "
"werkomstandigheden en ethische praktijken dekken."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s4
msgid ""
"<strong>{{ company_name }}</strong> applies policies on product\n"
"                                        safety, ethical marketing, consumer "
"privacy, and complaint\n"
"                                        handling. Policies align with "
"international standards such\n"
"                                        as <em>\n"
"                                            <strong>ISO 9001, ISO 26000, and "
"consumer protection\n"
"                                        regulations.</strong>\n"
"                                        </em>"
msgstr ""
"<strong>{{ company_name }}</strong> hanteert beleid op het gebied van "
"productveiligheid, ethische marketing, privacy van consumenten en "
"klachtenafhandeling. Dit beleid is in lijn met internationale normen zoals "
"<em><strong>ISO 9001, ISO 26000 en regelgeving voor consumentenbescherming.</"
"strong></em>"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e4
msgid ""
"<strong>{{ company_name }}</strong> assesses financial\n"
"                                            exposure to\n"
"                                            water-related risks (scarcity, "
"regulation, pollution\n"
"                                            events) and\n"
"                                            potential opportunities (cost "
"savings, sustainable\n"
"                                            branding). These\n"
"                                            assessments are integrated into "
"the enterprise risk\n"
"                                            management framework\n"
"                                            and scenario analyses."
msgstr ""
"<strong>{{ company_name }}</strong> beoordeelt de financiële blootstelling "
"aan watergerelateerde risico's (schaarste, regelgeving, "
"vervuilingsincidenten) en potentiële kansen (kostenbesparingen, duurzame "
"branding). Deze beoordelingen zijn geïntegreerd in het "
"ondernemingsrisicobeheer en scenarioanalyses."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"<strong>{{ company_name }}</strong> assesses financial\n"
"                                        exposure to\n"
"                                        water-related risks (scarcity, "
"regulation, pollution events)\n"
"                                        and potential\n"
"                                        opportunities (cost savings, "
"sustainable branding). These\n"
"                                        assessments are\n"
"                                        integrated into the enterprise risk "
"management framework and\n"
"                                        scenario\n"
"                                        analyses."
msgstr ""
"<strong>{{ company_name }}</strong> beoordeelt de financiële blootstelling "
"aan watergerelateerde risico's (schaarste, regelgeving, "
"vervuilingsincidenten) en potentiële kansen (kostenbesparingen, duurzame "
"branding). Deze beoordelingen zijn geïntegreerd in het "
"ondernemingsrisicobeheer en scenarioanalyses."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> assesses financial exposure to\n"
"                                pollution-related risks, including "
"regulatory changes, accidental\n"
"                                releases, and contamination of air, water, "
"and soil."
msgstr ""
"<strong>{{ company_name }}</strong> beoordeelt de financiële blootstelling "
"aan vervuilingsgerelateerde risico's, waaronder wetswijzigingen, "
"onopzettelijke lozingen en verontreiniging van lucht, water en bodem."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> assesses financial exposure to both\n"
"                                physical climate risks (e.g., extreme "
"weather, heat, flooding) and\n"
"                                transition risks (e.g., carbon pricing, "
"regulatory change,\n"
"                                technology shifts)."
msgstr ""
"<strong>{{ company_name }}</strong> beoordeelt de financiële blootstelling "
"aan zowel fysieke klimaatrisico's (bv. extreem weer, hitte, overstromingen) "
"als transitierisico's (bv. koolstofbeprijzing, wetswijzigingen, "
"technologische verschuivingen)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_appendix_environmental_a
msgid ""
"<strong>{{ company_name }}</strong> calculates its GHG emissions following "
"the <strong>GHG Protocol</strong>\n"
"                and <strong>Le Bilan Carbone®</strong> methodology. The "
"emissions are categorized\n"
"                into:"
msgstr ""
"<strong>{{ company_name }}</strong> berekent zijn broeikasgasemissies (BKG) "
"volgens het <strong>GHG Protocol</strong> en <strong>Le Bilan Carbone®</"
"strong>-methodologie. De emissies zijn onderverdeeld in:"

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> engages communities via consultations, "
"town halls,\n"
"                                                surveys, and collaborative "
"projects. Engagement\n"
"                                                identifies risks such as "
"displacement, environmental\n"
"                                                harm, or lack of economic "
"opportunities. Outcomes\n"
"                                                inform mitigation and "
"investment plans."
msgstr ""
"<strong>{{ company_name }}</strong> betrekt gemeenschappen via "
"raadplegingen, hoorzittingen, enquêtes en samenwerkingsprojecten. Deze "
"betrokkenheid identificeert risico's zoals ontheemding, milieuschade of "
"gebrek aan economische kansen. De resultaten vormen de basis voor mitigatie- "
"en investeringsplannen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> engages suppliers and their workers "
"through audits,\n"
"                                            surveys, and dialogue<strong>\n"
"                                                <em> platforms</em>\n"
"                                            </strong><em>\n"
"                                            .</em>Engagement aims to "
"identify and address issues\n"
"                                            such as excessive overtime, "
"discrimination, or lack of\n"
"                                            worker representation. Findings "
"feed into\n"
"                                            supplier-improvement plans."
msgstr ""
"<strong>{{ company_name }}</strong> betrekt leveranciers en hun werknemers "
"via audits,\n"
"                                            enquêtes en "
"dialoog<strong><em>platformen</em></strong><em>.\n"
"                                            </em>De betrokkenheid is erop "
"gericht om kwesties te identificeren en aan te pakken\n"
"                                            zoals buitensporige overuren, "
"discriminatie of een gebrek aan\n"
"                                            werknemersvertegenwoordiging. De "
"bevindingen worden verwerkt in\n"
"                                            plannen voor verbetering bij "
"leveranciers."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> engages workers via surveys, focus\n"
"                                groups, and consultation committees to "
"capture views on workplace\n"
"                                conditions and workforce impacts."
msgstr ""
"<strong>{{ company_name }}</strong> betrekt werknemers via enquêtes, "
"focusgroepen en overlegcomités om standpunten over werkomstandigheden en "
"effecten op het personeel te verzamelen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> ensures that all workers receive\n"
"                                wages meeting or exceeding legal minimums "
"and living wage benchmarks\n"
"                                where available. Regular reviews assess wage "
"competitiveness and\n"
"                                internal equity."
msgstr ""
"<strong>{{ company_name }}</strong> waarborgt dat alle werknemers een loon "
"ontvangen dat gelijk is aan of hoger is dan het wettelijk minimumloon en, "
"waar beschikbaar, de maatstaven voor een leefbaar loon. Regelmatige "
"evaluaties beoordelen het concurrentievermogen van de lonen en de interne "
"billijkheid."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> ensures that employees have the\n"
"                                right to freedom of association and "
"collective bargaining. Social\n"
"                                dialogue occurs through regular meetings "
"between management and\n"
"                                employee representatives at site and group "
"levels. Collective\n"
"                                agreements define working conditions, pay, "
"and benefits where\n"
"                                applicable."
msgstr ""
"<strong>{{ company_name }}</strong> zorgt ervoor dat werknemers het\n"
"                                recht op vrijheid van vereniging en "
"collectieve arbeidsonderhandelingen hebben. De sociale\n"
"                                dialoog vindt plaats via regelmatige "
"afspraken tussen het management en\n"
"                                werknemersvertegenwoordigers op locatie- en "
"groepsniveau. Collectieve\n"
"                                overeenkomsten definiëren "
"arbeidsvoorwaarden, beloning en secundaire arbeidsvoorwaarden waar\n"
"                                van toepassing."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e5
msgid ""
"<strong>{{ company_name }}</strong> evaluates\n"
"                                            financial impacts from\n"
"                                            resource-use and circular-"
"economy risks, integrating\n"
"                                            them into\n"
"                                            enterprise risk management. "
"Opportunities include\n"
"                                            cost savings,\n"
"                                            access to green financing, and "
"market growth for\n"
"                                            circular products."
msgstr ""
"<strong>{{ company_name }}</strong> evalueert de financiële impact van "
"risico's op het gebied van hulpbronnengebruik en circulaire economie en "
"integreert deze in het ondernemingsrisicobeheer. Kansen omvatten "
"kostenbesparingen, toegang tot groene financiering en marktgroei voor "
"circulaire producten."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> fosters inclusion for persons with "
"disabilities through\n"
"                                accessible recruitment, workplace "
"adaptation, and dedicated\n"
"                                training. Progress is monitored via self-"
"identification and HR\n"
"                                systems."
msgstr ""
"<strong>{{ company_name }}</strong> bevordert de inclusie van personen met "
"een handicap door middel van toegankelijke werving, aanpassing van de "
"werkplek en specifieke trainingen. De voortgang wordt gemonitord via "
"zelfidentificatie en HR-systemen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e4
msgid ""
"<strong>{{ company_name }}</strong> has developed a transition plan\n"
"                                    to ensure its business model and "
"strategy are compatible with\n"
"                                    global ecological thresholds, <strong>\n"
"                                        <em>including the Post-2020 Global "
"Biodiversity Framework\n"
"                                            and the EU\n"
"                                            Biodiversity Strategy for 2030</"
"em>\n"
"                                    </strong>.\n"
"                                    The plan addresses material impacts and "
"dependencies on\n"
"                                    biodiversity and ecosystems across own "
"operations and the value\n"
"                                    chain, using the mitigation hierarchy: "
"avoid, reduce, restore,\n"
"                                    and offset. Short-term (2025), medium-"
"term (2030), and long-term\n"
"                                    (2040-2050) milestones are defined, with "
"governance approval and\n"
"                                    monitoring systems in place."
msgstr ""
"<strong>{{ company_name }}</strong> heeft een overgangsplan ontwikkeld om "
"ervoor te zorgen dat zijn bedrijfsmodel en strategie verenigbaar zijn met "
"mondiale ecologische drempelwaarden, <strong><em>waaronder het Post-2020 "
"Global Biodiversity Framework en de EU-biodiversiteitsstrategie voor 2030</"
"em></strong>. Het plan behandelt materiële effecten op en afhankelijkheden "
"van biodiversiteit en ecosystemen binnen de eigen activiteiten en de "
"waardeketen, gebruikmakend van de mitigatiehiërarchie: vermijden, "
"verminderen, herstellen en compenseren. Mijlpalen voor de korte termijn "
"(2025), middellange termijn (2030) en lange termijn (2040-2050) zijn "
"gedefinieerd, met goedkeuring door bestuur en monitoringsystemen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> has established a transition plan\n"
"                                to align its activities with a 1.5°C "
"pathway, achieving net-zero GHG\n"
"                                emissions by <strong>\n"
"                                    <em>[insert year]</em>\n"
"                                </strong>.\n"
"                                The plan includes short-term (2025), medium-"
"term (2030), and\n"
"                                long-term (2040-2050) milestones."
msgstr ""
"<strong>{{ company_name }}</strong> heeft een overgangsplan opgesteld\n"
"                                om zijn activiteiten af te stemmen op een "
"1,5 °C-traject, waarbij netto-nul broeikasgasemissies\n"
"                                worden bereikt tegen <strong><em>[jaar "
"invoegen]</em></strong>.\n"
"                                Het plan omvat mijlpalen op korte termijn "
"(2025), middellange termijn (2030) en\n"
"                                lange termijn (2040-2050)."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> identifies substances of concern\n"
"                                (including SVHCs) in operations, products, "
"and supply chains.\n"
"                                Management measures include substitution, "
"safe handling, and\n"
"                                tracking of quantities used."
msgstr ""
"<strong>{{ company_name }}</strong> identificeert zorgwekkende stoffen "
"(inclusief SVHC's) in zijn activiteiten, producten en toeleveringsketens. "
"Beheersmaatregelen omvatten vervanging, veilige hantering en het bijhouden "
"van de gebruikte hoeveelheden."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s2
msgid ""
"<strong>{{ company_name }}</strong> implements\n"
"                                    supplier-training programs, capacity-"
"building partnerships, and\n"
"                                    collaborative industry initiatives to "
"reduce negative impacts on\n"
"                                    value-chain workers. Effectiveness is "
"evaluated by improvements\n"
"                                    in audit results, reduced complaints, "
"and supplier retention\n"
"                                    rates."
msgstr ""
"<strong>{{ company_name }}</strong> implementeert trainingsprogramma's voor "
"leveranciers, partnerschappen voor capaciteitsopbouw en gezamenlijke "
"sectorinitiatieven om negatieve effecten op werknemers in de waardeketen te "
"verminderen. De effectiviteit wordt geëvalueerd op basis van verbeteringen "
"in auditresultaten, vermindering van klachten en retentiegraden van "
"leveranciers."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s3
msgid ""
"<strong>{{ company_name }}</strong> implements community-investment\n"
"                                            programs, livelihood "
"initiatives, and collaborative\n"
"                                            mitigation projects. "
"Effectiveness is evaluated by\n"
"                                            reductions in complaints, "
"improved community\n"
"                                            satisfaction, and measurable "
"social outcomes."
msgstr ""
"<strong>{{ company_name }}</strong> implementeert investeringsprogramma's "
"voor de gemeenschap, initiatieven voor de middelen van bestaan en "
"gezamenlijke mitigatieprojecten. De effectiviteit wordt geëvalueerd door de "
"afname van klachten, verbeterde tevredenheid van de gemeenschap en meetbare "
"sociale resultaten."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> implements group-wide climate and\n"
"                                energy policies to steer operations toward "
"decarbonization and\n"
"                                resilience. Policies are endorsed by the "
"Board and integrated into\n"
"                                corporate governance."
msgstr ""
"<strong>{{ company_name }}</strong> implementeert groepsbreed klimaat- en\n"
"                                energiebeleid om de activiteiten te sturen "
"in de richting van decarbonisatie en\n"
"                                veerkracht. Het beleid wordt goedgekeurd "
"door de Raad van Bestuur en geïntegreerd in\n"
"                                bedrijfsvoering."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> implements group-wide pollution\n"
"                                policies endorsed by the Board, integrated "
"into operational\n"
"                                management and governance. Policies cover "
"prevention, monitoring,\n"
"                                and reporting of environmental impacts."
msgstr ""
"<strong>{{ company_name }}</strong> implementeert groepsbreed "
"vervuilingsbeleid dat is goedgekeurd door het bestuur en geïntegreerd in het "
"operationele beheer en governance. Het beleid omvat preventie, monitoring en "
"rapportage van milieueffecten."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> integrates carbon-cost\n"
"                                considerations into its decision-making to "
"anticipate regulatory,\n"
"                                market, and transition risks. The company "
"applies an internal carbon\n"
"                                price to guide capital allocation and "
"project evaluation."
msgstr ""
"<strong>{{ company_name }}</strong> integreert koolstofkostenoverwegingen in "
"haar besluitvorming om te anticiperen op regelgevings-, markt- en "
"transitierisico's. De onderneming hanteert een interne koolstofprijs om "
"kapitaaltoewijzing en projectevaluatie te sturen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> invests in continuous learning through "
"structured\n"
"                                programs, on-the-job training, and e-"
"learning. Focus areas include\n"
"                                digital skills, leadership, and "
"sustainability awareness."
msgstr ""
"<strong>{{ company_name }}</strong> investeert in continu leren via "
"gestructureerde programma's, training on the job en e-learning. "
"Focusgebieden zijn onder meer digitale vaardigheden, leiderschap en "
"bewustzijn op het gebied van duurzaamheid."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e3
msgid ""
"<strong>{{ company_name }}</strong> maintains comprehensive water\n"
"                                    and marine management policies approved "
"by senior leadership.\n"
"                                    These policies aim to ensure responsible "
"sourcing, efficient\n"
"                                    consumption, and safe return of water to "
"the environment, while\n"
"                                    safeguarding ocean ecosystems."
msgstr ""
"<strong>{{ company_name }}</strong> hanteert een uitgebreid beleid voor "
"water- en marien beheer, goedgekeurd door het senior management. Dit beleid "
"is erop gericht om verantwoorde inkoop, efficiënt verbruik en een veilige "
"terugkeer van water naar het milieu te waarborgen, terwijl de ecosystemen "
"van de oceaan worden beschermd."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_g1
msgid ""
"<strong>{{ company_name }}</strong> maintains corporate culture and\n"
"                                    business conduct policies covering "
"ethical behavior,\n"
"                                    whistleblowing, anti-corruption, and "
"responsible\n"
"                                    decision-making. Policies align with "
"OECD Guidelines, UN Global\n"
"                                    Compact, and ISO 37001 anti-bribery "
"standards."
msgstr ""
"<strong>{{ company_name }}</strong> hanteert beleid voor de bedrijfscultuur "
"en zakelijk gedrag dat ethisch gedrag, klokkenluidersregelingen, "
"anticorruptie en verantwoorde besluitvorming dekt. Het beleid is in lijn met "
"de OESO-richtlijnen, het UN Global Compact en de ISO 37001-normen voor de "
"bestrijding van omkoping."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c5
msgid ""
"<strong>{{ company_name }}</strong> monitors additional workforce "
"characteristics to provide a complete view of its human capital management. "
"This section includes management-level gender ratios and information on self-"
"employed and temporary workers engaged by the company. Data is collected "
"from employee application."
msgstr ""
"<strong>{{ company_name }}</strong> houdt aanvullende kenmerken van het "
"personeelsbestand bij om een volledig beeld te geven van het human capital "
"management. Dit gedeelte bevat de geslachtsverhoudingen op managementniveau "
"en informatie over zelfstandigen en tijdelijke werknemers die door het "
"bedrijf zijn ingehuurd. De gegevens worden verzameld via de "
"sollicitatieformulieren van werknemers."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> monitors any GHG removal activities\n"
"                                or carbon credit projects linked to its "
"operations. These may\n"
"                                include carbon sequestration in soils, "
"forests, or technological\n"
"                                capture, and participation in certified "
"carbon offset programs."
msgstr ""
"<strong>{{ company_name }}</strong> monitort alle activiteiten voor "
"koolstofverwijdering of koolstofcreditprojecten die gekoppeld zijn aan zijn "
"activiteiten. Dit kan koolstofvastlegging in bodems of bossen omvatten, of "
"technologische opvang, evenals deelname aan gecertificeerde "
"koolstofoffsetprogramma's."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> progressively increases renewable\n"
"                                energy share through Power Purchase "
"Agreements and on-site\n"
"                                generation."
msgstr ""
"<strong>{{ company_name }}</strong> verhoogt geleidelijk het aandeel "
"hernieuwbare energie via afnameovereenkomsten (PPA's) en eigen opwekking op "
"locatie."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> promotes equal opportunity and\n"
"                                diversity at all levels. Metrics include "
"gender, age, nationality,\n"
"                                and underrepresented groups. Diversity "
"targets are integrated into\n"
"                                leadership evaluations and HR processes."
msgstr ""
"<strong>{{ company_name }}</strong> bevordert gelijke kansen en diversiteit "
"op alle niveaus. De metrieken omvatten gender, leeftijd, nationaliteit en "
"ondervertegenwoordigde groepen. Diversiteitsdoelstellingen zijn geïntegreerd "
"in de evaluaties van het leiderschap en de HR-processen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid ""
"<strong>{{ company_name }}</strong> provides formal channels for\n"
"                                workers to report concerns, including "
"whistleblowing hotlines,\n"
"                                email, and direct contact with HR. "
"Remediation processes ensure\n"
"                                timely follow-up, investigation, and "
"resolution of issues."
msgstr ""
"<strong>{{ company_name }}</strong> biedt formele kanalen voor werknemers om "
"zorgen te melden, waaronder klokkenluidersregelingen, e-mail en direct "
"contact met HR. Herstelprocessen waarborgen tijdige opvolging, onderzoek en "
"oplossing van kwesties."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e1
msgid ""
"<strong>{{ company_name }}</strong> quantifies its greenhouse-gas (GHG)\n"
"                                emissions following recognised accounting "
"principles consistent with\n"
"                                the GHG Protocol Corporate Standard and ESRS "
"E1-6."
msgstr ""
"<strong>{{ company_name }}</strong> kwantificeert zijn broeikasgasemissies "
"(GHG) volgens erkende boekhoudprincipes die consistent zijn met de GHG "
"Protocol Corporate Standard en ESRS E1-6."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_e2
msgid ""
"<strong>{{ company_name }}</strong> tracks emissions and discharges\n"
"                                systematically across all relevant "
"operational sites. Data\n"
"                                collection is aligned with the EMS and "
"reported consistently to\n"
"                                management and regulatory authorities."
msgstr ""
