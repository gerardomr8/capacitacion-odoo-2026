msgid ""
"<strong>\n"
"                                    <em>{{ company_name }}</em>\n"
"                                </strong>operates\n"
"                                grievance mechanisms enabling confidential "
"reporting of workplace\n"
"                                concerns, including discrimination, "
"harassment, or labor rights\n"
"                                breaches. All cases are logged, "
"investigated, and remediated. Severe\n"
"                                impacts are escalated to executive level and "
"disclosed\n"
"                                transparently."
msgstr ""
"<strong><em>{{ company_name }}</em></strong> hanteert klachtenmechanismen "
"die een vertrouwelijke melding van zorgen op de werkplek mogelijk maken, "
"waaronder discriminatie, intimidatie of inbreuken op arbeidsrechten. Alle "
"gevallen worden geregistreerd, onderzocht en hersteld. Ernstige effecten "
"worden geëscaleerd naar directieniveau en transparant bekendgemaakt."

