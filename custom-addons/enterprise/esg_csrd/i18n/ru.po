#. module: esg_csrd
#: model:mail.template,body_html:esg_csrd.mail_template_esg_metric_ask_feedback
msgid ""
"<t t-set=\"logged_user\" t-value=\"ctx.get('logged_user')\"/>\n"
"                <t t-set=\"company_name\" t-value=\"ctx.get('company_name')"
"\"/>\n"
"                <t t-set=\"deadline\" t-value=\"ctx.get('deadline')\"/>\n"
"                <div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;"
"\">\n"
"                        </p><p style=\"margin-left:5px\">Dear <t t-"
"out=\"object.partner_id.name or 'stakeholder'\">[Stakeholder]</t></p>\n"
"                        <span>\n"
"                            <t t-out=\"logged_user\">[Current user]</t> "
"invites you to participate in the CSRD double materiality review for <t t-"
"out=\"company_name\">[Company Name]</t>. We are looking for your input on: "
"<br/>\n"
"                            - How the company impacts the environment, "
"society, and the economy. <br/>\n"
"                            - How these impacts could affect the company "
"financially. <br/>\n"
"                            Please complete your review by <t t-"
"out=\"deadline\">[specified deadline]</t> to help us meet CSRD requirements. "
"Your expertise is important for an accurate assessment. </span>\n"
"                        <br/> Thank you for your contribution. <br/>\n"
"                        Best regards, <t t-out=\"logged_user\">[Current "
"user]</t>\n"
"                        <br/><br/>\n"
"                        <div style=\"margin: 16px 0px 16px 0px; text-align: "
"center;\">\n"
"                            <a t-att-href=\"object.get_start_url()\" t-attf-"
"style=\"background-color: {{user.company_id.email_secondary_color or "
"'#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: "
"{{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; "
"font-size:13px;\">\n"
"                                Start the Review\n"
"                            </a>\n"
"                        </div>\n"
"                    \n"
"                </div>\n"
"            "
msgstr ""
"<t t-set=\"logged_user\" t-value=\"ctx.get('logged_user')\"/>\n"
"                <t t-set=\"company_name\" t-value=\"ctx.get('company_name')"
"\"/>\n"
"               <t t-set=\"deadline\" t-value=\"ctx.get('deadline')\"/>\n"
"                <div style=\"margin: 0px; padding: 0px;\">\n"
"                   <p style=\"margin: 0px; padding: 0px; font-size: 13px;"
"\">\n"
"                        </p> <p style=\"margin-left:5px\">Здравствуйте, <t t-"
"out=\"object.partner_id.name or 'stakeholder'\">[Заинтересованная сторона]</"
"t>!</p>\n"
"                       <span>\n"
"                            <t t-out=\"logged_user\">[Текущий пользователь]</"
"t> приглашает вас принять участие в анализе двойной существенности CSRD для "
"компании <t t-out=\"company_name\">[Название компании]</t>. Мы хотим узнать "
"ваше мнение по следующим вопросам: <br/>\n"
"                            - Как компания влияет на окружающую среду, "
"общество и экономику. <br/>\n"
"                            - Как это влияние может отразиться на финансовом "
"положении компании. <br/>\n"
"                            Пожалуйста, завершите ваш обзор до <t t-"
"out=\"deadline\">[указанный срок]</t>, чтобы помочь нам выполнить требования "
"CSRD. Ваш опыт важен для получения точной оценки. </span>\n"
"                        <br/> Благодарим вас за вклад. <br/>\n"
"                        С уважением, <t t-out=\"logged_user\">[Текущий "
"пользователь]</t>\n"
"                        <br/><br/>\n"
"                        <div style=\"margin: 16px 0px 16px 0px; text-align: "
"center;\"> \n"
"                           <a t-att-href=\"object.get_start_url()\" t-attf-"
"style=\"background-color: {{user.company_id.email_secondary_color or "
"'#875A7B'}}; padding: 8px 16px 8px 16px; text-decoration: none; color: "
"{{user.company_id.email_primary_color or '#FFFFFF'}}; border-radius: 5px; "
"font-size:13px;\"> \n"
"                                Начать обзор\n"
"                           </a>\n"
"                        </div> \n"
"                    \n"
"               </div> \n"
"            "

