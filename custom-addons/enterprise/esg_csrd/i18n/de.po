#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c6
msgid "A simple risk-identification practice qualifies as “due diligence.”"
msgstr ""
"Eine einfache Methode zur Risikoidentifizierung gilt als „Sorgfaltspflicht“."

#. module: esg_csrd
#: model:ir.model.constraint,message:esg_csrd.constraint_esg_tag_name_uniq
msgid "A tag with the same name already exists."
msgstr "Es besteht bereits ein Stichwort mit demselben Namen."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_vsm_c1
msgid ""
"A topic is considered double material when both impact and financial scores "
"meet or exceed this threshold."
msgstr ""
"Ein Thema gilt als doppeltes Material, wenn sowohl die Auswirkungs- als auch "
"die Finanzbewertung diesen Schwellenwert erreichen oder überschreiten."

#. module: esg_csrd
#: model_terms:knowledge.article,template_body:esg_csrd.esg_csrd_knowledge_article_template_csrd_esrs_s1
msgid "Accessible facilities (%)"
