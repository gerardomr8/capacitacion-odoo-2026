msgid ""
"<strong>\n"
"                                    <em>{{ company_name }}</em>\n"
"                                </strong>operates\n"
"                                grievance mechanisms enabling confidential "
"reporting of workplace\n"
"                                concerns, including discrimination, "
"harassment, or labor rights\n"
"                                breaches. All cases are logged, "
"investigated, and remediated. Severe\n"
"                                impacts are escalated to executive level and "
"disclosed\n"
"                                transparently."
msgstr ""
"<strong>\n"
"                                    <em>{{ company_name }}</em>\n"
"                               </strong> verfügt über\n"
"                                Beschwerdemechanismen, die eine vertrauliche "
"Meldung von Problemen am Arbeitsplatz\n"
"                                ermöglichen, einschließlich Diskriminierung, "
"Belästigung oder Verstößen gegen Arbeitsrechte.\n"
"                                Alle Fälle werden protokolliert, untersucht "
"und behoben. Schwerwiegende\n"
"                                Auswirkungen werden an die Führungsebene "
"eskaliert und\n"
"                                transparent offengelegt."

