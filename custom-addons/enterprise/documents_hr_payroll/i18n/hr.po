msgid "%s Payslip(s) correctly sent."
msgstr "%s isplata/e ispravno poslana/e."

#. module: documents_hr_payroll
#: model:mail.template,body_html:documents_hr_payroll.mail_template_new_payslip
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
"        <t t-set=\"document_access_link\" t-"
"value=\"object.document_access_url\"/>\n"
"        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;"
"\">\n"
"            Dear <t t-out=\"object.employee_id.name\"/>, a new payslip is "
"available for you.<br/><br/>\n"
"            <t t-if=\"object.employee_id.user_id\">Please find the PDF in "
"your employee portal.<br/><br/></t>\n"
"            <div t-if=\"document_access_link\" style=\"text-align: center; "
"padding: 16px 0px 16px 0px; font-size: 14px;\">\n"
"                <a t-attf-href=\"{{ document_access_link }}\" "
"target=\"_blank\" style=\"background-color: #875A7B; padding: 8px 16px 8px "
"16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;"
"\">\n"
"                    Your Payslip\n"
"                </a>\n"
"            </div>\n"
"            Have a nice day,<br/>\n"
"            The HR Team\n"
"        </td></tr>\n"
"    </tbody></table>\n"
"                "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
"        <t t-set=\"document_access_link\" t-"
"value=\"object.document_access_url\"/>\n"
"        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;\">"
"\n"
"            Poštovani/a <t t-out=\"object.employee_id.name\"/>, nova isplata "
"je dostupna za vas.<br/><br/>\n"
"            <t t-if=\"object.employee_id.user_id\">PDF možete pronaći u "
"portalu zaposlenika.<br/><br/></t>\n"
"            <div t-if=\"document_access_link\" style=\"text-align: center; "
"padding: 16px 0px 16px 0px; font-size: 14px;\">\n"
"                <a t-attf-href=\"{{ document_access_link }}\" "
"target=\"_blank\" style=\"background-color: #875A7B; padding: 8px 16px 8px "
"16px; text-decoration: none; color: #fff; border-radius: 5px; font-"
"size:13px;\">\n"
"                    Vaša isplata\n"
"                </a>\n"
"            </div>\n"
"            Ugodan dan,<br/>\n"
"            HR tim\n"
"        </td></tr>\n"
"    </tbody></table>\n"
"                "

#. module: documents_hr_payroll
#: model:mail.template,body_html:documents_hr_payroll.mail_template_new_declaration
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; "
"margin:0px auto;\"><tbody>\n"
