#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "%(b_open)sContracts & NDAs%(b_close)s go to the %(legal)s folder."
msgstr "%(b_open)sUgovori i NDA-ovi%(b_close)s idu u mapu %(legal)s."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"%(b_open)sInsurance contracts%(b_close)s go to the %(insurance)s folder."
msgstr "%(b_open)sUgovori o osiguranju%(b_close)s idu u mapu %(insurance)s."

#. module: ai_documents_account
#: model:ir.model.fields,field_description:ai_documents_account.field_documents_document__ai_document_or_env_company_id
msgid "AI Company"
msgstr "AI tvrtka"

#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_ai_documents_sort
msgid "Ai Documents Sort"
msgstr "AI sortiranje dokumenata"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Company > Email"
msgstr "Tvrtka > e-mail"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Company > Name"
msgstr "Tvrtka > naziv"

#. module: ai_documents_account
#: model:ir.model.fields,field_description:ai_documents_account.field_ai_documents_sort__display_name
#: model:ir.model.fields,field_description:ai_documents_account.field_documents_document__display_name
#: model:ir.model.fields,field_description:ai_documents_account.field_ir_actions_server__display_name
msgid "Display Name"
msgstr "Naziv za prikaz"

#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_documents_document
msgid "Document"
msgstr "Dokument"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"First, check the file to see if it contains a single document or if several "
"documents are collated together."
msgstr ""
"Prvo provjerite datoteku kako biste utvrdili sadrži li samo jedan dokument "
"ili je više dokumenata spojeno zajedno."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "For this, use this field: %s"
msgstr "Za to upotrijebite ovo polje: %s"

#. module: ai_documents_account
#: model:ir.model.fields,field_description:ai_documents_account.field_ai_documents_sort__id
#: model:ir.model.fields,field_description:ai_documents_account.field_documents_document__id
#: model:ir.model.fields,field_description:ai_documents_account.field_ir_actions_server__id
msgid "ID"
msgstr "ID"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "If it is a customer invoice, trigger the action to create one."
msgstr "Ako se radi o kupčevom računu, pokrenite radnju za njegovo kreiranje."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "If it is false, continue with the normal process"
msgstr "Ako je netočno, nastavite s uobičajenim postupkom"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If it is true, add the tag %(b_open)s\"To Split\"%(b_close)s and stop there. "
"This way, we'll know we first need to manually split it into different files."
msgstr ""
"Ako je točno, dodajte oznaku %(b_open)s\"Za podjelu\"%(b_close)s i "
"zaustavite se. Tako ćemo znati da je prvo potrebno ručno podijeliti u "
"različite datoteke."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer is %(b_open)sanyone else%(b_close)s, create a Customer "
"Invoice."
msgstr ""
"Ako je kupac %(b_open)sbilo tko drugi%(b_close)s, kreirajte izlazni račun."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer is %s it means it is a vendor bill, trigger the Create "
"Vendor Bill action."
msgstr ""
"Ako je kupac %s, to znači da je to ulazni račun dobavljača, pokrenite radnju "
"kreiranja ulaznog računa."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer of the invoice is us (%(company_name)s, with email %"
"(company_email)s), create a Vendor Bill."
msgstr ""
"Ako smo mi kupac na računu (%(company_name)s, s e-mailom %(company_email)s), "
"kreirajte ulazni račun dobavljača."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the document is %(b_open)snot an invoice%(b_close)s, move it to the "
"correct folder:"
msgstr ""
"Ako dokument %(b_open)snije račun%(b_close)s, premjestite ga u ispravnu mapu:"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the document is an %(b_open)sinvoice%(b_close)s, move it to the %"
"(finance)s folder then trigger the relevant action:"
msgstr ""
"Ako je dokument %(b_open)sračun%(b_close)s, premjestite ga u mapu %(finance)"
"s i zatim pokrenite odgovarajuću radnju:"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Is considered multipage"
msgstr "Smatra se višestraničnim"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Otherwise, %s"
msgstr "U suprotnom, %s"

#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_ir_actions_server
msgid "Server Action"
msgstr "Serverske radnje"

#. module: ai_documents_account
#: model:documents.tag,name:ai_documents_account.documents_tag_to_split
msgid "To Split"
msgstr "Za podjelu"
