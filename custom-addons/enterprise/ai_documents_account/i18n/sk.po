#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_documents_document
msgid "Document"
msgstr "Dokument"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"First, check the file to see if it contains a single document or if several "
"documents are collated together."
msgstr ""
"Najskôr skontrolujte súbor, či obsahuje jediný dokument, alebo či je v ňom "
"zozbieraných viacero dokumentov."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "For this, use this field: %s"
msgstr "Na tento účel použite toto pole: %s"

#. module: ai_documents_account
#: model:ir.model.fields,field_description:ai_documents_account.field_ai_documents_sort__id
#: model:ir.model.fields,field_description:ai_documents_account.field_documents_document__id
#: model:ir.model.fields,field_description:ai_documents_account.field_ir_actions_server__id
msgid "ID"
msgstr "ID"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "If it is a customer invoice, trigger the action to create one."
msgstr "Ak ide o faktúru pre zákazníka, spustite akciu na jej vytvorenie."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "If it is false, continue with the normal process"
msgstr "Ak je to nepravda, pokračujte bežným postupom"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If it is true, add the tag %(b_open)s\"To Split\"%(b_close)s and stop there. "
"This way, we'll know we first need to manually split it into different files."
msgstr ""
"Ak je to pravda, pridajte štítok %(b_open)s „Na rozdelenie“%(b_close)s a "
"skončite. Takto budeme vedieť, že dokument najprv musíme ručne rozdeliť do "
"rôznych súborov."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer is %(b_open)sanyone else%(b_close)s, create a Customer "
"Invoice."
msgstr ""
"Ak je zákazník %(b_open)salebo niekto iný%(b_close)s, vytvorte faktúru pre "
"zákazníka."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer is %s it means it is a vendor bill, trigger the Create "
"Vendor Bill action."
msgstr ""
"Ak zákazník je %s, znamená to, že ide o faktúru dodávateľa, spustite akciu "
"Vytvoriť faktúru dodávateľa."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the customer of the invoice is us (%(company_name)s, with email %"
"(company_email)s), create a Vendor Bill."
msgstr ""
"Ak sme my zákazníkom faktúry (%(company_name)s, s e-mailom %(company_email)s)"
", vytvorte faktúru dodávateľa."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the document is %(b_open)snot an invoice%(b_close)s, move it to the "
"correct folder:"
msgstr ""
"Ak dokument nie je faktúrou%(b_close)s, ale objednávkou %(b_open)s, presuňte "
"ho do správnej zložky:"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"If the document is an %(b_open)sinvoice%(b_close)s, move it to the %"
"(finance)s folder then trigger the relevant action:"
msgstr ""
"Ak je dokument typu %(b_open)sfaktúra%(b_close)s, presuňte ho do priečinka %"
"(finance)s a potom spustite príslušnú akciu:"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Is considered multipage"
msgstr "Považuje sa za viacstránkový dokument"

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid "Otherwise, %s"
msgstr "V opačnom prípade, %s"

#. module: ai_documents_account
#: model:ir.model,name:ai_documents_account.model_ir_actions_server
msgid "Server Action"
msgstr "Serverová akcia"

#. module: ai_documents_account
#: model:documents.tag,name:ai_documents_account.documents_tag_to_split
msgid "To Split"
msgstr "Na rozdelenie"
