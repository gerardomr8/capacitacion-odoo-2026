"%(b_open)sZmluvy a dohody o mlčanlivosti (NDA)%(b_close)s uložte do "
"priečinka %(legal)s."

#. module: ai_documents_account
#. odoo-python
#: code:addons/ai_documents_account/wizard/ai_documents_sort.py:0
msgid ""
"%(b_open)sInsurance contracts%(b_close)s go to the %(insurance)s folder."
msgstr ""
"%(b_open)sPoisťovacie zmluvy%(b_close)s uložte do priečinka %(insurance)s."

