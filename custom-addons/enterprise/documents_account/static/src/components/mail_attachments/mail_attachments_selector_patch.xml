<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="documents_account.MailComposerAttachmentSelector"
       t-inherit="mail.MailComposerAttachmentSelector"
       t-inherit-mode="extension">
        <xpath expr="//FileUploader" position="after">
            <t t-if="this.addDocumentsAttachment" t-call="documents.MailComposerDocumentSelector"/>
        </xpath>
    </t>
</templates>
