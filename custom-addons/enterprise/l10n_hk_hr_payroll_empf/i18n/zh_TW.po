#: code:addons/l10n_hk_hr_payroll_empf/model/l10n_hk_empf_contribution_report.py:0
msgid ""
"You must set a Birthday for all new employees being registered to the eMPF "
"system."
msgstr "所有註冊至積金易系統的新員工，必須設定出生日期。"

#. module: l10n_hk_hr_payroll_empf
#. odoo-python
#: code:addons/l10n_hk_hr_payroll_empf/model/l10n_hk_empf_contribution_report.py:0
msgid ""
"You must set a Identification No or Passport No for all employees using the "
"eMPF system."
msgstr "所有使用積金易系統的員工，必須設定身份證號碼或護照號碼。"

#. module: l10n_hk_hr_payroll_empf
#. odoo-python
#: code:addons/l10n_hk_hr_payroll_empf/model/l10n_hk_empf_contribution_report.py:0
msgid ""
"You must set a Private Email for all new employees being registered to the "
"eMPF system."
msgstr "所有註冊至積金易系統的新員工，必須設定私人電郵地址。"

#. module: l10n_hk_hr_payroll_empf
#. odoo-python
#: code:addons/l10n_hk_hr_payroll_empf/model/l10n_hk_empf_contribution_report.py:0
msgid ""
"You must set a Private Phone for all new employees being registered to the "
"eMPF system."
msgstr "所有註冊至積金易系統的新員工，必須設定私人電話號碼。"

#. module: l10n_hk_hr_payroll_empf
#. odoo-python
#: code:addons/l10n_hk_hr_payroll_empf/model/l10n_hk_empf_contribution_report.py:0
msgid ""
"You must set a Reason Of Termination (eMPF) for all departure types used by "
"the eMPF system."
msgstr "所有離職類型都必須設定「終止僱用原因（積金易）」，以供積金易系統使用。"

#. module: l10n_hk_hr_payroll_empf
#. odoo-python
#: code:addons/l10n_hk_hr_payroll_empf/model/hr_version.py:0
msgid ""
"You must set the %(start_date_string)s for employee %(employee_name)s in "
"order to properly calculate the vested percentage."
msgstr ""
"你必須為員工 %(employee_name)s 設定「%(start_date_string)s」，以便正確計算歸"
"屬百分比。"

