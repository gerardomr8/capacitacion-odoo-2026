<?xml version="1.0" encoding="utf-8"?>
<odoo auto_sequence="1">
    <record id="balance_sheet" model="account.report">
        <field name="name">Balance Sheet</field>
        <field name="root_report_id" ref="account_reports.balance_sheet"/>
        <field name="country_id" ref="base.us"/>
        <field name="column_ids">
            <record id="balance_sheet_balance" model="account.report.column">
                <field name="name">Balance</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="assets" model="account.report.line">
                <field name="name">Assets</field>
                <field name="hierarchy_level">0</field>
                <field name="code">TA</field>
                <field name="horizontal_split_side">left</field>
                <field name="aggregation_formula">CA.balance + FA.balance + OA.balance</field>
                <field name="children_ids">
                    <record id="assets_current_assets" model="account.report.line">
                        <field name="name">Current Assets</field>
                        <field name="code">CA</field>
                        <field name="aggregation_formula">BA.balance + REC.balance + OCAS.balance</field>
                        <field name="children_ids">
                            <record id="assets_current_assets_bank_and_cash" model="account.report.line">
                                <field name="name">Bank and Cash</field>
                                <field name="code">BA</field>
                                <field name="groupby">account_id</field>
                                <field name="foldable" eval="True"/>
                                <field name="domain_formula">sum([('account_id.account_type', '=', 'asset_cash')])</field>
                            </record>
                            <record id="assets_current_assets_ar" model="account.report.line">
                                <field name="name">Accounts Receivable</field>
                                <field name="code">REC</field>
                                <field name="groupby">account_id</field>
                                <field name="foldable" eval="True"/>
                                <field name="domain_formula">sum([('account_id.account_type', '=', 'asset_receivable'), ('account_id.non_trade', '=', False)])</field>
                            </record>
                            <record id="assets_current_assets_other_current_assets" model="account.report.line">
                                <field name="name">Other Current Assets</field>
                                <field name="code">OCAS</field>
                                <field name="groupby">account_id</field>
                                <field name="foldable" eval="True"/>
                                <field name="domain_formula">sum(['|', ('account_id.account_type', 'in', ('asset_current', 'asset_prepayments')), '&amp;', ('account_id.account_type', '=', 'asset_receivable'), ('account_id.non_trade', '=', True)])</field>
                            </record>
                        </field>
                    </record>
                    <record id="assets_fixed_assets" model="account.report.line">
                        <field name="name">Fixed Assets</field>
                        <field name="code">FA</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="domain_formula">sum([('account_id.account_type', '=', 'asset_fixed')])</field>
                    </record>
                    <record id="assets_other_assets" model="account.report.line">
                        <field name="name">Other Assets</field>
                        <field name="code">OA</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="domain_formula">sum([('account_id.account_type', '=', 'asset_non_current')])</field>
                    </record>
                </field>
            </record>
            <record id="liabilities_equity" model="account.report.line">
                <field name="name">Liabilities &amp; Equity</field>
                <field name="hierarchy_level">0</field>
                <field name="code">LE</field>
                <field name="horizontal_split_side">right</field>
                <field name="expression_ids">
                    <record id="liabilities_equity_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">LI.balance + EQ.balance</field>
                        <field name="green_on_positive" eval="False"/>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="liabilities" model="account.report.line">
                        <field name="name">Liabilities</field>
                        <field name="code">LI</field>
                        <field name="expression_ids">
                            <record id="liabilities_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">CL.balance + LTL.balance</field>
                                <field name="green_on_positive" eval="False"/>
                            </record>
                        </field>
                        <field name="children_ids">
                            <record id="liabilities_current_liabilities" model="account.report.line">
                                <field name="name">Current Liabilities</field>
                                <field name="code">CL</field>
                                <field name="expression_ids">
                                    <record id="liabilities_current_liabilities_balance" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">AP.balance + CC.balance + OCL.balance</field>
                                        <field name="green_on_positive" eval="False"/>
                                    </record>
                                </field>
                                <field name="children_ids">
                                    <record id="liabilities_current_liabilities_ap" model="account.report.line">
                                        <field name="name">Accounts Payable</field>
                                        <field name="code">AP</field>
                                        <field name="groupby">account_id</field>
                                        <field name="foldable" eval="True"/>
                                        <field name="expression_ids">
                                            <record id="liabilities_current_liabilities_ap_balance" model="account.report.expression">
                                                <field name="label">balance</field>
                                                <field name="engine">domain</field>
                                                <field name="formula" eval="[('account_id.account_type', '=', 'liability_payable'), ('account_id.non_trade', '=', False)]"/>
                                                <field name="subformula">-sum</field>
                                                <field name="green_on_positive" eval="False"/>
                                            </record>
                                        </field>
                                    </record>
                                   <record id="liabilities_current_liabilities_credit_cards" model="account.report.line">
                                        <field name="name">Credit Cards</field>
                                        <field name="code">CC</field>
                                        <field name="groupby">account_id</field>
                                        <field name="foldable" eval="True"/>
                                        <field name="expression_ids">
                                            <record id="liabilities_current_liabilities_credit_cards_balance" model="account.report.expression">
                                                <field name="label">balance</field>
                                                <field name="engine">domain</field>
                                                <field name="formula" eval="[('account_id.account_type', '=', 'liability_credit_card')]"/>
                                                <field name="subformula">-sum</field>
                                                <field name="green_on_positive" eval="False"/>
                                            </record>
                                        </field>
                                    </record>
                                   <record id="liabilities_current_liabilities_other_current_liabilities" model="account.report.line">
                                        <field name="name">Other Current Liabilities</field>
                                        <field name="code">OCL</field>
                                        <field name="groupby">account_id</field>
                                        <field name="foldable" eval="True"/>
                                        <field name="expression_ids">
                                            <record id="liabilities_current_liabilities_other_current_liabilities_balance" model="account.report.expression">
                                                <field name="label">balance</field>
                                                <field name="engine">domain</field>
                                                <field name="formula" eval="['|', ('account_id.account_type', '=', 'liability_current'), '&amp;', ('account_id.account_type', '=', 'liability_payable'), ('account_id.non_trade', '=', True)]"/>
                                                <field name="subformula">-sum</field>
                                                <field name="green_on_positive" eval="False"/>
                                            </record>
                                        </field>
                                    </record>
                                </field>
                            </record>
                            <record id="liabilities_long_liabilities" model="account.report.line">
                                <field name="name">Long-term Liabilities</field>
                                <field name="code">LTL</field>
                                <field name="groupby">account_id</field>
                                <field name="foldable" eval="True"/>
                                <field name="expression_ids">
                                    <record id="liabilities_long_liabilities_balance" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">domain</field>
                                        <field name="formula" eval="[('account_id.account_type', '=', 'liability_non_current')]"/>
                                        <field name="subformula">-sum</field>
                                        <field name="green_on_positive" eval="False"/>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>
                    <record id="equity" model="account.report.line">
                        <field name="name">Equity (&amp; Earnings)</field>
                        <field name="hierarchy_level">0</field>
                        <field name="code">EQ</field>
                        <field name="horizontal_split_side">right</field>
                        <field name="aggregation_formula">EQU.balance + EAR.balance</field>
                        <field name="children_ids">
                            <record id="equity1" model="account.report.line">
                                <field name="name">Equity</field>
                                <field name="code">EQU</field>
                                <field name="expression_ids">
                                    <record id="equity1_balance" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">domain</field>
                                        <field name="formula" eval="[('account_id.account_type', '=', 'equity')]"/>
                                        <field name="date_scope">from_beginning</field>
                                        <field name="subformula">-sum</field>
                                    </record>
                                </field>
                            </record>
                            <record id="earnings" model="account.report.line">
                                <field name="name">Earnings</field>
                                <field name="code">EAR</field>
                                <field name="aggregation_formula">PYE.balance + CYE.balance</field>
                                <field name="children_ids">
                                    <record id="current_years_earnings" model="account.report.line">
                                        <field name="name">Current Year Unallocated Earnings</field>
                                        <field name="code">CYE</field>
                                        <field name="expression_ids">
                                            <record id="current_year_earnings_balance" model="account.report.expression">
                                                <field name="label">balance</field>
                                                <field name="engine">domain</field>
                                                <field name="formula" eval="[('account_id.account_type', 'in', ['income', 'income_other', 'expense_direct_cost', 'expense', 'expense_depreciation', 'expense_other', 'equity_unaffected'])]"/>
                                                <field name="date_scope">from_fiscalyear</field>
                                                <field name="subformula">-sum</field>
                                            </record>
                                        </field>
                                    </record>
                                    <record id="previous_years_earnings" model="account.report.line">
                                        <field name="name">Previous Year Earnings</field>
                                        <field name="code">PYE</field>
                                        <field name="expression_ids">
                                            <record id="previous_year_earnings_balance" model="account.report.expression">
                                                <field name="label">balance</field>
                                                <field name="engine">domain</field>
                                                <field name="formula" eval="[('account_id.account_type', 'in', ['income', 'income_other', 'expense_direct_cost', 'expense', 'expense_depreciation', 'expense_other', 'equity_unaffected'])]"/>
                                                <field name="date_scope">to_beginning_of_fiscalyear</field>
                                                <field name="subformula">-sum</field>
                                            </record>
                                        </field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="off_balance" model="account.report.line">
                <field name="name">Off Balance Sheet Accounts</field>
                <field name="hierarchy_level">0</field>
                <field name="code">OS</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="hide_if_zero" eval="1"/>
                <field name="domain_formula">-sum([('account_id.account_type', '=', 'off_balance')])</field>
            </record>
        </field>
    </record>
</odoo>
