<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_financial_report_l10n_uz_pl" model="account.report">
        <field name="name">Profit and Loss</field>
        <field name="name@uz">Foyda va zarar hisoboti</field>
        <field name="root_report_id" ref="account_reports.profit_and_loss"/>
        <field name="country_id" ref="base.uz"/>
        <field name="column_ids">
            <record id="account_financial_report_l10n_uz_pl_balance" model="account.report.column">
                <field name="name">Balance</field>
                <field name="name@uz">Saldo</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
        <field name="line_ids">
            <record id="account_financial_report_l10n_uz_pl_pl" model="account.report.line">
                <field name="name">[0100] - Profit or Loss</field>
                <field name="name@uz">[0100] - Foyda va zararlar</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                </field>
                <field name="children_ids">
                    <record id="account_financial_report_l10n_uz_pl_rev" model="account.report.line">
                        <field name="name">[0110] - Revenue</field>
                        <field name="name@uz">[0110] - Tushum</field>
                        <field name="code">REV</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_pl_rev_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">-tag(l10n_uz.account_tag_pl_0110)</field>
                            </record>
                        </field>
                    </record>
                    <record id="account_financial_report_l10n_uz_pl_cos" model="account.report.line">
                        <field name="name">[0120] - Cost of Sales</field>
                        <field name="name@uz">[0120] - Sotish tannarxi</field>
                        <field name="code">COS</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_pl_cos_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">tag(l10n_uz.account_tag_pl_0120)</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_gp" model="account.report.line">
                <field name="name">[0200] - Gross Profit (Loss) (0110-0120)</field>
                <field name="name@uz">[0200] - Yalpi foyda (zarar) (satr. 0101-0102)</field>
                <field name="code">GP</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_gp_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">REV.balance - COS.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_othoi" model="account.report.line">
                <field name="name">[0210] - Other Operating Income</field>
                <field name="name@uz">[0210] - Operatsion faoliyatning boshqa daromadlari</field>
                <field name="code">OTHOI</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_othoi_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0210)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_se" model="account.report.line">
                <field name="name">[0220] - Selling Expenses</field>
                <field name="name@uz">[0220] - Sotish xarajatlari</field>
                <field name="code">SE</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_se_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0220)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_gae" model="account.report.line">
                <field name="name">[0230] - General &amp; Administrative Expenses</field>
                <field name="name@uz">[0230] - Maʼmuriy xarajatlar</field>
                <field name="code">GAE</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_gae_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0230)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_ila" model="account.report.line">
                <field name="name">[0240] - Impairment Losses on Assets</field>
                <field name="name@uz">[0240] - Aktivlarni qadrsizlanishidan zararlar</field>
                <field name="code">ILA</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_ila_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0240)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_othoe" model="account.report.line">
                <field name="name">[0250] - Other Operating Expenses</field>
                <field name="name@uz">[0250] - Operatsion faoliyatning boshqa xarajatlari</field>
                <field name="code">OTHOE</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_othoe_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0250)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_op" model="account.report.line">
                <field name="name">[0300] - Operating Profit (Loss) (0200+0210-0220-0230-0240-0250)</field>
                <field name="name@uz">[0300] - Operatsion faoliyat foydasi (zarari) (satr. 0200+0210-0220-0230-0240-0250)</field>
                <field name="code">OP</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_op_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">GP.balance - OTHOI.balance - SE.balance - GAE.balance - ILA.balance - OTHOE.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_pajv" model="account.report.line">
                <field name="name">[0310] - Share of Profit (Loss) of Associates &amp; Joint Ventures</field>
                <field name="name@uz">[0310] - Taʼsir ostidagi tashkilotlar va qoʻshma korxonalarning foydasining (zararining) tashkilotga tegishli ulushi</field>
                <field name="code">PAJV</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_pajv_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0310)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_fc_ibl" model="account.report.line">
                <field name="name">[0320] - Finance Costs (Interest on Borrowings &amp; Leases)</field>
                <field name="name@uz">[0320] - Qarzlar va moliyaviy ijara boʻyicha foizlar shaklidagi xarajatlar</field>
                <field name="code">FC_IBL</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_fc_ibl_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0320)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_forex" model="account.report.line">
                <field name="name">[0330] - Foreign Exchange Gain (Loss)</field>
                <field name="name@uz">[0330] - Valyuta kursi farqidan foyda (zarar)</field>
                <field name="code">FOREX</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_forex_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0330)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_othfi" model="account.report.line">
                <field name="name">[0340] - Other Finance Income</field>
                <field name="name@uz">[0340] - Moliyaviy faoliyatning boshqa daromadlari</field>
                <field name="code">OTHFI</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_othfi_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0340)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_ofc" model="account.report.line">
                <field name="name">[0350] - Other Finance Costs</field>
                <field name="name@uz">[0350] - Moliyaviy faoliyat boʻyicha boshqa xarajatlari</field>
                <field name="code">OFC</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_ofc_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0350)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_bef_tax" model="account.report.line">
                <field name="name">[0400] - Profit (Loss) Before Income Tax (0300+/-0310-0320+/-0330+0340-0350)</field>
                <field name="name@uz">[0400] - Foyda soligʻi toʻlangunga qadar foyda yoki zarar (satr. 0300+/-0310-0320+/-0330+0340-0350)</field>
                <field name="code">BEF_TAX</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_bef_tax_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">OP.balance + PAJV.balance - FC_IBL.balance + FOREX.balance + OTHFI.balance - OFC.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_ite" model="account.report.line">
                <field name="name">[0410] - Income Tax Expense, Total (0420+0430)</field>
                <field name="name@uz">[0410] - Foyda soligʻi, jami (satr. 0420+0430), shu jumladan:</field>
                <field name="code">ITE</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_ite_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">CIT.balance + DTE.balance</field>
                    </record>
                </field>
                <field name="children_ids">
                    <record id="account_financial_report_l10n_uz_pl_cit" model="account.report.line">
                        <field name="name">[0420] - Current Income Tax Expense</field>
                        <field name="name@uz">[0420] - Joriy foyda soligʻi xarajati</field>
                        <field name="code">CIT</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_pl_cit_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">tag(l10n_uz.account_tag_pl_0420)</field>
                            </record>
                        </field>
                    </record>
                    <record id="account_financial_report_l10n_uz_pl_dte" model="account.report.line">
                        <field name="name">[0430] - Deferred Tax Expense (Income)</field>
                        <field name="name@uz">[0430] - Kechiktirilgan soliq xarajati (daromadi)</field>
                        <field name="code">DTE</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_pl_dte_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">tag(l10n_uz.account_tag_pl_0430)</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_pco" model="account.report.line">
                <field name="name">[0500] - Profit (Loss) from Continuing Operations (0400-0410)</field>
                <field name="name@uz">[0500] - Davom etayotgan faoliyatdan foyda (zarar) (satr. 0400-0410)</field>
                <field name="code">PCO</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_pco_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">BEF_TAX.balance - ITE.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_pdo" model="account.report.line">
                <field name="name">[0510] - Profit (Loss) from Discontinued Operations</field>
                <field name="name@uz">[0510] - Tugatilgan faoliyatdan foyda (zarar)</field>
                <field name="code">PDO</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_pdo_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0510)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_np_rp" model="account.report.line">
                <field name="name">[0600] - Net Profit (Loss) for the Reporting Period (0500+0510)</field>
                <field name="name@uz">[0600] - Hisobot davri uchun sof foyda (zarar) (satr. 0500+0510)</field>
                <field name="code">NP_RP</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_np_rp_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">PCO.balance + PDO.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_oth_ci" model="account.report.line">
                <field name="name">[0700] - Other Comprehensive Income (OCI)</field>
                <field name="name@uz">[0700] - Boshqa umumlashgan daromadlar</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_reval" model="account.report.line">
                <field name="name">[0710] - Revaluation Surplus on Fixed Assets &amp; Intangibles (Revaluation Model)</field>
                <field name="name@uz">[0710] - Qayta baholash modeliga muvofiq baholanadigan asosiy vositalar va nomoddiy aktivlar
                    uchun qayta baholash natijasida qiymatning oʻsishidagi oʻzgarishlar</field>
                <field name="code">REVAL</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_reval_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0710)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_ci_ajv" model="account.report.line">
                <field name="name">[0720] - Share of OCI of Associates &amp; Joint Ventures</field>
                <field name="name@uz">[0720] - Taʼsir ostidagi tashkilotlar va qoʻshma korxonalarning boshqa umumlashgan
                    daromadining (zararining) tashkilotga tegishli ulushi</field>
                <field name="code">CI_AJV</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_ci_ajv_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0720)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_it_nrec" model="account.report.line">
                <field name="name">[0730] - Income Tax Effects on Non-Reclassifiable Items</field>
                <field name="name@uz">[0730] - Reklassifikatsiya qilinmaydigan moddalar boʻyicha foyda soligʻi taʼsirlari</field>
                <field name="code">IT_NREC</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_it_nrec_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0730)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_oth_nrec" model="account.report.line">
                <field name="name">[0800] - OCI — Items Not Reclassified to P&amp;L (net of tax) (0710+/-0720-0730)</field>
                <field name="name@uz">[0800] - Keyingi davrlarda foyda yoki zararda reklassifikatsiya qilinmaydigan
                    boshqa umumlashgan daromadlar (foyda soligʻi taʼsirlarini chegirgan holda) (satr. 0710+/-0720-0730)</field>
                <field name="code">OTH_NREC</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_oth_nrec_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">REVAL.balance + CI_AJV.balance + IT_NREC.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_erdf" model="account.report.line">
                <field name="name">[0810] - Exchange Differences on Translation of Foreign Operations</field>
                <field name="name@uz">[0810] - Chet eldagi boʻlinmani boshqa valyutaga oʻtkazishda yuzaga keladigan kurs farqlari</field>
                <field name="code">ERDF</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_erdf_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0810)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_fvoci" model="account.report.line">
                <field name="name">[0820] - Fair Value Changes on Financial Instruments at FVOCI</field>
                <field name="name@uz">[0820] - Boshqa umumlashgan daromad orqali haqqoniy qiymatda baholanadigan moliyaviy
                    instrumentlarni qayta baholash natijasida qiymatning oʻsishidagi oʻzgarishlar</field>
                <field name="code">FVOCI</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_fvoci_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0820)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_cfh" model="account.report.line">
                <field name="name">[0830] - Cash Flow Hedges</field>
                <field name="name@uz">[0830] - Pul oqimini xejlash</field>
                <field name="code">CFH</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_cfh_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0830)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_pl_hnifd" model="account.report.line">
                <field name="name">[0840] - Hedges of Net Investment in Foreign Operations</field>
                <field name="name@uz">[0840] - Chet eldagi boʻlinmaga sof investitsiyalarni xejlash</field>
                <field name="code">HNIFD</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_pl_hnifd_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">-tag(l10n_uz.account_tag_pl_0840)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_it_rec" model="account.report.line">
                <field name="name">[0850] - Income Tax Effects on Reclassifiable Items</field>
                <field name="name@uz">[0850] - Keyingi davrlarda foyda yoki zararda reklassifikatsiya qilinishi mumkin
                    boʻlgan moddalar boʻyicha foyda soligʻi taʼsirlari</field>
                <field name="code">IT_REC</field>
                <field name="groupby">account_id</field>
                <field name="foldable" eval="True"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_it_rec_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">account_codes</field>
                        <field name="formula">tag(l10n_uz.account_tag_pl_0850)</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_othci_rec" model="account.report.line">
                <field name="name">[0900] - OCI — Items That May Be Reclassified to P&amp;L (net of tax) (0810+/-0820+/-0830+/-0840-0850)</field>
                <field name="name@uz">[0900] - Keyingi davrlarda foyda yoki zararda reklassifikatsiya qilinishi mumkin boʻlgan
                    boshqa umumlashgan daromadlar (foyda soligʻi taʼsirlarini chegirgan holda) (satr. 0810+/-0820+/-0830+/-0840-0850)</field>
                <field name="code">OTHCI_REC</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_othci_rec_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">ERDF.balance + FVOCI.balance + CFH.balance + HNIFD.balance + IT_REC.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_othci_rp" model="account.report.line">
                <field name="name">[1000] - Total OCI for the Reporting Period (0800+0900)</field>
                <field name="name@uz">[1000] - Hisobot davri uchun jami boshqa umumlashgan daromadlar (satr. 0800+0900)</field>
                <field name="code">OTHCI_RP</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_othci_rp_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">OTH_NREC.balance + OTHCI_REC.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_ci_rp" model="account.report.line">
                <field name="name">[1010] - Total Comprehensive Income for the Reporting Period (0600+1000)</field>
                <field name="name@uz">[1010] - Hisobot davri uchun jami umumlashgan daromad (0600+1000)</field>
                <field name="code">CI_RP</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                    <record id="account_financial_report_l10n_uz_ci_rp_balance" model="account.report.expression">
                        <field name="label">balance</field>
                        <field name="engine">aggregation</field>
                        <field name="formula">NP_RP.balance + OTHCI_RP.balance</field>
                    </record>
                </field>
            </record>
            <record id="account_financial_report_l10n_uz_eps" model="account.report.line">
                <field name="name">[1020] - Earnings Per Share (in UZS):</field>
                <field name="name@uz">[1020] - Bir aksiyaga toʻgʻri keladigan foyda (soʻmda):</field>
                <field name="hierarchy_level" eval="0"/>
                <field name="expression_ids">
                </field>
                <field name="children_ids">
                    <record id="account_financial_report_l10n_uz_eps_basic" model="account.report.line">
                        <field name="name">[1030] - Basic EPS</field>
                        <field name="name@uz">[1030] - bazaviy koʻrsatkich</field>
                        <field name="code">EPS_BASIC</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_eps_basic_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">tag(l10n_uz.account_tag_pl_1030)</field>
                            </record>
                        </field>
                    </record>
                    <record id="account_financial_report_l10n_uz_eps_diluted" model="account.report.line">
                        <field name="name">[1040] - Diluted EPS</field>
                        <field name="name@uz">[1040] - suyultirilgan koʻrsatkich</field>
                        <field name="code">EPS_DILUTED</field>
                        <field name="groupby">account_id</field>
                        <field name="foldable" eval="True"/>
                        <field name="expression_ids">
                            <record id="account_financial_report_l10n_uz_eps_diluted_balance" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">account_codes</field>
                                <field name="formula">tag(l10n_uz.account_tag_pl_1040)</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
        </field>
    </record>
</odoo>
