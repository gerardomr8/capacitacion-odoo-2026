#. module: pos_enterprise_sms_whatsapp
#: model:sms.template,body:pos_enterprise_sms_whatsapp.sms_template_order_received_confirmation_pos
msgid ""
"Hello {{ object.partner_id.name }},\n"
"\n"
"Thank you for your order number {{ object.pos_reference }} for the {{ object.preset_time }}.\n"
"You will soon be notified when your order is ready.\n"
"\n"
"{{ object.company_id.name }}\n"
"\n"
"            "
msgstr ""
"Dzień dobry {{ object.partner_id.name }},\n"
"\n"
"Dziękujemy za Twoje zamówienie numer {{ object.pos_reference }} - {{ "
"object.preset_time }}.\n"
"Zostaniesz poinformowany, kiedy zamówienie będzie gotowe.\n"
"\n"
"{{ object.company_id.name }}\n"
"\n"
"            "

#. module: pos_enterprise_sms_whatsapp
#: model:sms.template,body:pos_enterprise_sms_whatsapp.sms_template_order_ready_pos
msgid ""
"Hello {{ object.partner_id.name }},\n"
"\n"
"Your order number {{ object.pos_reference }} is now ready for pickup. Head over whenever you're ready, and enjoy your meal.\n"
"\n"
"{{ object.company_id.name }}\n"
"\n"
"            "
msgstr ""
"Dzień dobry {{ object.partner_id.name }},\n"
"\n"
"Twoje zamówienie numer {{ object.pos_reference }} jest gotowe do odbioru. "
"Odbierz je w dogodnym czasie. Smacznego!\n"
"\n"
"{{ object.company_id.name }}\n"
"\n"
"            "

