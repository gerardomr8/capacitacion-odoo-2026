msgstr "De underordnade utgör vinsten i tillgångens värde"

#. module: account_asset
#. odoo-python
#: code:addons/account_asset/controller/asset_template_controller.py:0
msgid ""
"The code or name of the associated journal in Odoo for depreciation entries "
"(e.g., MISC - Miscellaneous Operations, INV - Customer Invoices, BILL - "
"Vendor Bills)."
msgstr ""
"Koden eller namnet på den relaterade bokföringsjournalen i Odoo för "
"avskrivningsposter (t.ex., MISC - Diverse operationer, INV - Kundfakturor, "
"BILL - Leverantörsfakturor)."

#. module: account_asset
#: model:ir.model.fields,help:account_asset.field_asset_modify__invoice_ids
