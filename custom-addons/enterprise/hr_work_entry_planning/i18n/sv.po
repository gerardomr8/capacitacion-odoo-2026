#. module: hr_work_entry_planning
#: model:ir.model.fields,help:hr_work_entry_planning.field_hr_employee__work_entry_source
#: model:ir.model.fields,help:hr_work_entry_planning.field_hr_version__work_entry_source
msgid ""
"\n"
"        Defines the source for work entries generation\n"
"\n"
"        Working Schedule: Work entries will be generated from the working "
"hours below.\n"
"        Attendances: Work entries will be generated from the employee's "
"attendances. (requires Attendance app)\n"
"        Planning: Work entries will be generated from the employee's "
"planning. (requires Planning app)\n"
"    "
msgstr ""
"\n"
"        Anger en källa när arbetsposter skapas\n"
"\n"
"        Arbetsschema: Arbetsposter skapas utifrån arbetstiderna och schemat "
"nedan.\n"
"        Närvaro: Arbetsposter skapas utifrån den anställdes närvaro (kräver "
"appen Närvaro).\n"
"        Planering: Arbetsposter skapas utifrån den anställdes "
"planeringsschema (kräver appen Planering).\n"
"    "

