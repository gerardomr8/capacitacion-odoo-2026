"                            done tomorrow.\n"
"                        </span>"
msgstr ""
"<span invisible=\"nb_products_selected &lt;= 1000\">\n"
"                            Budući da se dnevno može obraditi samo 1000 "
"proizvoda, preostali će\n"
"                            biti obrađeni sutra.\n"
"                        </span>"

