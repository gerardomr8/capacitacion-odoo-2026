<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_be_pos_blackbox.MustClockInPopup">
        <Dialog size="'lg'">
            <t t-set-slot="header">
                <h4 class="modal-title text-break">
                    Clock In Required
                </h4>
            </t>
            <div class="mb-3">
                <div>
                    You must be clocked in before paying an order.
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="button btn btn-lg btn-primary"
                    t-on-click="() => this.clockIn()">
                    Clock In
                </button>
            </t>
        </Dialog>
    </t>
</templates>
