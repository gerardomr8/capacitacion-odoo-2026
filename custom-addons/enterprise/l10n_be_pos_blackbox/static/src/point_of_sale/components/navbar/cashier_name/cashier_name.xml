<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="l10n_be_pos_blackbox.CashierName" t-inherit="point_of_sale.CashierName" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('cashier-name')]" position="attributes">
            <attribute name="class">cashier-name btn btn-light position-relative p-1</attribute>
        </xpath>
        <xpath expr="//button[hasclass('cashier-name')]" position="inside">
            <t t-if="pos.blackbox.isActive">
                <i t-att-class="clockIconClass"
                    style="padding: 6px; bottom: 1px; right: 1px; cursor: auto;"
                    t-att-title="pos.isCashierClockedIn() ? 'Clocked in' : 'Clocked out'">
                </i>
            </t>
        </xpath>
    </t>
</templates>
