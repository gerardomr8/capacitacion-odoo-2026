<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.Chrome" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos')]" position="inside">
            <t t-if="pos.blackbox.isActive and pos.config.l10n_be_training_mode">
                <div class="w-100 position-absolute bottom-0 bg-danger text-white d-flex justify-content-center align-items-center">
                    <span>BLACKBOX TRAINING MODE</span>
                </div>
            </t>
        </xpath>
    </t>
</templates>
