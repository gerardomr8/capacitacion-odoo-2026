<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academy_student_form" model="ir.ui.view">
        <field name="name">academy.student.form</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <form string="Student Form">
                <sheet>
                    <group>
                        <field name="photo" string="Foto" widget="image"/>
                        <field name="name"/>
                        <field name="last_name"/>
                        <field name="email"/>
                        <field name="birthdate"/>
                        <field name="product"/>                        
                        <field name="school_id" readonly="1"/>
                        <field name="course_ids">
                            <list string="Courses">
                                <field name="name"/>
                                <field name="description"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_academy_student_list" model="ir.ui.view">
        <field name="name">academy.student.list</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <list string="Student List">
                <field name="name"/>
                <field name="last_name"/>
                <field name="email"/>
                <field name="birthdate"/>
            </list>
        </field>
    </record>

    <record id="action_academy_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">academy.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_academy_root"
        name="Academy"
        sequence="10"
        groups="base.group_user"
        />    
    
    <menuitem
        id="menu_academy_student"
        name="Students"
        parent="menu_academy_root"
        action="action_academy_student"
        sequence="10"/>

</odoo>
