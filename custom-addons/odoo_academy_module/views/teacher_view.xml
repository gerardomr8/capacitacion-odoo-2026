<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academy_teacher_form" model="ir.ui.view">
        <field name="name">academy.teacher.form</field>
        <field name="model">academy.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher Form">
                <sheet>
                    <group>
                        <field name="photo" widget="image" options="{'size': [100, 100]}"/>
                        <field name="name"/>
                        <field name="biography"/>
                        <field name="director_id"/>
                        <field name="curse_ids">
                            <list string="Courses">
                                <field name="name"/>
                                <field name="description"/>
                            </list>
                        </field>
                        <field name="school_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>    

    <record id="view_academy_teacher_list" model="ir.ui.view">
        <field name="name">academy.teacher.list;</field>
        <field name="model">academy.teacher</field>
        <field name="arch" type="xml">
            <list string="Teacher List"> 
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_academy_teacher" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">academy.teacher</field>
        <field name="view_mode">list,form</field>
    </record>    

    <menuitem
        id="model_teacher_menu"
        name="Teachers"
        action="action_academy_teacher"
        parent="menu_academy_root"
        sequence="30"
        groups="odoo_academy_module.group_academy_teacher"
        />
</odoo>
