<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_academy_director_form" model="ir.ui.view">
        <field name="name">academy.director.form</field>
        <field name="model">academy.director</field>
        <field name="arch" type="xml">
            <form string="Director Form">
                <sheet>
                    <group>
                        <field name="photo" widget="image" options="{'size': [100, 100]}"/>
                        <field name="name"/>
                        <field name="last_name"/>
                        <field name="email"/>
                        <field name="birthdate"/>
                        <field name="school_id"/>
                        <field name="teacher_ids">
                            <list string="Teachers">
                                <field name="name"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_academy_director_list" model="ir.ui.view">
        <field name="name">academy.director.list;</field>
        <field name="model">academy.director</field>
        <field name="arch" type="xml">
            <list string="Director List"> 
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_academy_director" model="ir.actions.act_window">
        <field name="name">Directors</field>
        <field name="res_model">academy.director</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="model_director_menu"
        name="Directors"
        action="action_academy_director"
        parent="menu_academy_root"
        sequence="50"/>
</odoo>