<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_academy_course_form" model="ir.ui.view">
        <field name="name">academy.course.form</field>
        <field name="model">academy.course</field>
        <field name="arch" type="xml">
            <form string="Course Form">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>

                        <field name="student_ids">
                            <list string="Students">
                                <field name="name"/>
                                <field name="last_name"/>
                                <field name="school_id"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_academy_course_list" model="ir.ui.view">
        <field name="name">academy.course.list</field>
        <field name="model">academy.course</field>
        <field name="arch" type="xml">
            <list string="Course List">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_academy_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">academy.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="model_course_menu"
        name="Courses"
        action="action_academy_course"
        parent="menu_academy_root"
        sequence="20"/>
</odoo>